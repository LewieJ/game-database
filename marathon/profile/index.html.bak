<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Marathon player profile on MarathonDB — loadout builder, stats, collection.">
    <meta name="robots" content="index, follow">
    <link rel="icon" type="image/png" href="/Icon.png">
    <link rel="apple-touch-icon" href="/Icon.png">
    <meta property="og:type" content="profile">
    <meta property="og:title" content="Player Profile | MarathonDB">
    <meta property="og:description" content="View Marathon player profile — loadout builder, stats, and collection progress.">
    <meta property="og:image" content="https://marathondb.gg/Icon.png">
    <meta property="og:site_name" content="MarathonDB">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="@MarathonDB">
    <meta name="theme-color" content="#d4ff00">
    <title>Player Profile | MarathonDB</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/pages.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar navbar--edge">
        <div class="nav-inner nav-inner--edge">
            <div class="nav-left">
                <a href="/" class="nav-logo">
                    <img src="/Icon.png" alt="MarathonDB" class="logo-icon" width="28" height="28">
                    <span>MARATHON<span class="logo-accent">DB</span></span>
                </a>
            </div>
            <div class="nav-center">
                <a href="/weapons/" class="nav-link">Weapons</a>
                <a href="/runners/" class="nav-link">Runners</a>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-toggle">
                        Leaderboards
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M6 9l6 6 6-6"/></svg>
                    </button>
                    <div class="nav-dropdown-menu">
                        <span class="nav-dropdown-item nav-dropdown-item--disabled">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
                            Ranked Leaderboards
                            <span style="font-size:0.65rem;opacity:0.5;margin-left:auto">Coming Soon</span>
                        </span>
                        <span class="nav-dropdown-item nav-dropdown-item--disabled">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
                            General Leaderboards
                            <span style="font-size:0.65rem;opacity:0.5;margin-left:auto">Coming Soon</span>
                        </span>
                    </div>
                </div>
                <span class="nav-divider"></span>
                <a href="/cores/" class="nav-link">Cores</a>
                <a href="/implants/" class="nav-link">Implants</a>
                <a href="/mods/" class="nav-link">Mods</a>
                <a href="/items/" class="nav-link">Items</a>
                <span class="nav-divider"></span>
                <div class="nav-dropdown nav-dropdown--cosmetics">
                    <button class="nav-dropdown-toggle nav-dropdown-toggle--cosmetics">
                        Cosmetics
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M6 9l6 6 6-6"/></svg>
                    </button>
                    <div class="nav-dropdown-menu">
                        <a href="/weapon-skins/" class="nav-dropdown-item">Weapon Skins</a>
                        <a href="/runner-skins/" class="nav-dropdown-item">Runner Skins</a>
                        <div class="nav-dropdown-divider"></div>
                        <a href="/stickers/" class="nav-dropdown-item">Stickers</a>
                        <a href="/backgrounds/" class="nav-dropdown-item">Backgrounds</a>
                        <a href="/charms/" class="nav-dropdown-item">Charms</a>
                        <a href="/emblems/" class="nav-dropdown-item">Emblems</a>
                    </div>
                </div>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-toggle">
                        Store
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M6 9l6 6 6-6"/></svg>
                    </button>
                    <div class="nav-dropdown-menu">
                        <span class="nav-dropdown-item nav-dropdown-item--disabled">In-Game Store <span style="font-size:0.65rem;opacity:0.5;margin-left:auto">Coming Soon</span></span>
                    </div>
                </div>
                <span class="nav-divider"></span>
                <a href="/factions/" class="nav-link">Factions</a>
                <a href="/tier-lists/" class="nav-link">Tier Lists</a>
                <div class="nav-dropdown">
                    <button class="nav-dropdown-toggle">
                        More
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M6 9l6 6 6-6"/></svg>
                    </button>
                    <div class="nav-dropdown-menu">
                        <a href="/loadout-builder/" class="nav-dropdown-item">Loadout Builder</a>
                        <div class="nav-dropdown-divider"></div>
                        <a href="/news/" class="nav-dropdown-item">News</a>
                        <a href="/population/" class="nav-dropdown-item">Population</a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Search Overlay -->
    <div class="nav-search-overlay" id="navSearchOverlay">
        <div class="nav-search-container">
            <form class="search-form nav-search-form">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                <input type="text" name="q" class="search-input nav-search-input" placeholder="Search weapons, runners, items..." autocomplete="off">
                <span class="search-shortcut">ESC</span>
            </form>
            <button class="nav-search-close" id="navSearchClose">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
    </div>

    <!-- ═══ PROFILE PAGE ═══ -->
    <main class="pf-page">
    <div class="ad-page-wrapper">

        <!-- Left Siderail Ad -->
        <aside class="ad-siderail ad-siderail--left">
            <div class="ad-siderail-sticky">
                <span class="ad-label">Ad</span>
                <div class="ad-container">
                    <ins class="adsbygoogle" style="display:block"
                         data-ad-client="ca-pub-1865737750178944" data-ad-slot="4717575097"
                         data-ad-format="auto"
                         data-full-width-responsive="true"></ins>
                    <script>try{(adsbygoogle = window.adsbygoogle || []).push({})}catch(e){}</script>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="pf-page-content">

        <!-- Loading -->
        <div class="pf-loading" id="profileLoading">
            <div class="loading-spinner"></div>
            <span>Loading profile...</span>
        </div>

        <!-- Error -->
        <div id="profileError" style="display:none;" class="pf-error-wrap">
            <div class="pf-error">
                <div class="pf-error-title" id="errorTitle">Profile Not Found</div>
                <p class="pf-error-text" id="errorText">The requested profile could not be found.</p>
                <a href="/player-profiles/" class="pf-back-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
                    Back to Player Search
                </a>
            </div>
        </div>

        <!-- Profile content -->
        <div id="profileContent" style="display:none;">

            <!-- Early development notice -->
            <div class="pf-api-notice">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                These pages are in early development. Features may change, break, or be reset as we continue building.
            </div>

            <!-- ── BANNER ── -->
            <div class="pf-banner" id="pfBanner">
                <div class="pf-banner-fade"></div>
                <div class="pf-banner-content">
                    <div class="pf-identity">
                        <div class="pf-avatar-wrap" id="pfAvatarWrap">
                            <img id="pfAvatar" src="" alt="" class="pf-avatar">
                            <div class="pf-avatar-placeholder" id="pfAvatarPlaceholder">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                        </div>
                        <div class="pf-name-area">
                            <div class="pf-username" id="pfUsername"></div>
                            <div class="pf-subtitle" id="pfSubtitle"></div>
                            <div class="pf-badges" id="pfBadges"></div>
                        </div>
                    </div>
                    <div class="pf-header-right">
                        <div class="pf-header-actions">
                            <button class="pf-share-btn" id="pfShareBtn" title="Copy profile link">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── TAB BAR ── -->
            <div class="pf-tabs-wrap">
                <div class="pf-tabs" id="pfTabs">
                    <button class="pf-tab pf-tab--disabled" data-tab="overview">
                        Overview <span class="pf-tab-soon">Soon</span>
                    </button>
                    <button class="pf-tab active" data-tab="upgrades">Faction Upgrades</button>
                    <button class="pf-tab" data-tab="loadout" style="display:none">Loadout Builder</button>
                </div>
            </div>

            <!-- ═══ TAB: OVERVIEW (greyed out) ═══ -->
            <div class="pf-tab-panel" id="tab-overview"></div>

            <!-- ═══ TAB: FACTION UPGRADES ═══ -->
            <div class="pf-tab-panel active" id="tab-upgrades">
                <!-- Faction selector bar -->
                <div class="fu-faction-bar" id="fuFactionBar"></div>
                <!-- Progress header -->
                <div class="fu-progress" id="fuProgress"></div>
                <!-- Upgrades list -->
                <div class="fu-upgrades-list" id="fuUpgradesList"></div>
                <!-- Capstones -->
                <div class="fu-capstones" id="fuCapstones"></div>
            </div>

            <!-- ═══ TAB: LOADOUT BUILDER ═══ -->
            <div class="pf-tab-panel" id="tab-loadout">

                <!-- Runner selector bar -->
                <div class="lb-runner-bar">
                    <div class="lb-runner-bar-inner" id="runnerSelectorBar">
                        <span class="lb-runner-bar-loading">Loading runners...</span>
                    </div>
                </div>

                <!-- Main loadout area -->
                <div class="lb-main" id="lbMain">
                    <!-- Empty state -->
                    <div class="lb-empty" id="lbEmpty">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="64" height="64" opacity="0.15"><circle cx="12" cy="5" r="3"/><path d="M6.5 8C9 14 9 15.6 9 20"/><path d="M17.5 8C15 14 15 15.6 15 20"/><path d="M7 14h10"/></svg>
                        <div class="lb-empty-title">Select a Runner</div>
                        <div class="lb-empty-text">Choose a runner above to start building your loadout</div>
                    </div>

                    <!-- Active loadout (hidden until runner selected) -->
                    <div class="lb-active" id="lbActive" style="display:none;">

                        <!-- Three column layout -->
                        <div class="lb-columns">

                            <!-- ── LEFT: Runner info + stats ── -->
                            <div class="lb-col-left">
                                <div class="lb-runner-header">
                                    <div class="lb-runner-name" id="lbRunnerName">DESTROYER</div>
                                    <div class="lb-runner-role" id="lbRunnerRole">Combat specialist · Assault / Defend</div>
                                    <div class="lb-runner-desc" id="lbRunnerDesc"></div>
                                </div>

                                <!-- Abilities -->
                                <div class="lb-abilities" id="lbAbilities"></div>

                                <!-- Runner stat bars -->
                                <div class="lb-stats" id="lbRunnerStats"></div>
                            </div>

                            <!-- ── CENTER: Runner hero + equipment slots ── -->
                            <div class="lb-col-center">
                                <div class="lb-hero-area">
                                    <!-- Equipment slot -->
                                    <div class="lb-equip-col lb-equip-left">
                                        <button class="lb-slot" data-slot="equipment" id="slotEquipment">
                                            <span class="lb-slot-label">EQUIPMENT</span>
                                            <span class="lb-slot-icon" id="slotEquipmentIcon"></span>
                                        </button>
                                    </div>

                                    <!-- Shield slot -->
                                    <div class="lb-equip-col lb-equip-right-top">
                                        <button class="lb-slot" data-slot="shield" id="slotShield">
                                            <span class="lb-slot-label">SHIELD</span>
                                            <span class="lb-slot-icon" id="slotShieldIcon"></span>
                                        </button>
                                    </div>

                                    <!-- Runner hero image -->
                                    <div class="lb-hero-img-wrap">
                                        <img class="lb-hero-img" id="lbHeroImg" src="" alt="">
                                    </div>

                                    <!-- Cores -->
                                    <div class="lb-equip-col lb-equip-cores">
                                        <span class="lb-equip-section-label">CORES</span>
                                        <button class="lb-slot lb-slot--sm" data-slot="core1" id="slotCore1">
                                            <span class="lb-slot-icon" id="slotCore1Icon"></span>
                                        </button>
                                        <button class="lb-slot lb-slot--sm" data-slot="core2" id="slotCore2">
                                            <span class="lb-slot-icon" id="slotCore2Icon"></span>
                                        </button>
                                    </div>

                                    <!-- Implants -->
                                    <div class="lb-equip-col lb-equip-implants">
                                        <span class="lb-equip-section-label">IMPLANTS</span>
                                        <div class="lb-implant-row">
                                            <button class="lb-slot lb-slot--sm" data-slot="head" id="slotHead">
                                                <span class="lb-slot-icon" id="slotHeadIcon"></span>
                                            </button>
                                            <button class="lb-slot lb-slot--sm" data-slot="torso" id="slotTorso">
                                                <span class="lb-slot-icon" id="slotTorsoIcon"></span>
                                            </button>
                                            <button class="lb-slot lb-slot--sm" data-slot="legs" id="slotLegs">
                                                <span class="lb-slot-icon" id="slotLegsIcon"></span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ── RIGHT: Weapon + mods + weapon stats ── -->
                            <div class="lb-col-right">
                                <!-- Weapon area -->
                                <div class="lb-weapon-section">
                                    <span class="lb-section-label">WEAPON</span>
                                    <div class="lb-weapon-top">
                                        <div class="lb-weapon-mods-grid">
                                            <button class="lb-slot lb-slot--sm" data-slot="mod1" id="slotMod1" disabled>
                                                <span class="lb-slot-icon" id="slotMod1Icon"></span>
                                            </button>
                                            <button class="lb-slot lb-slot--sm" data-slot="mod2" id="slotMod2" disabled>
                                                <span class="lb-slot-icon" id="slotMod2Icon"></span>
                                            </button>
                                            <button class="lb-slot lb-slot--sm" data-slot="mod3" id="slotMod3" disabled>
                                                <span class="lb-slot-icon" id="slotMod3Icon"></span>
                                            </button>
                                            <button class="lb-slot lb-slot--sm" data-slot="mod4" id="slotMod4" disabled>
                                                <span class="lb-slot-icon" id="slotMod4Icon"></span>
                                            </button>
                                        </div>
                                        <button class="lb-weapon-slot" data-slot="weapon" id="slotWeapon">
                                            <span class="lb-weapon-slot-label">Select Weapon</span>
                                            <img class="lb-weapon-img" id="lbWeaponImg" src="" alt="" style="display:none;">
                                        </button>
                                    </div>
                                </div>

                                <!-- Weapon stats -->
                                <div class="lb-weapon-stats" id="lbWeaponStats">
                                    <div class="lb-ws-empty">Select a weapon to view stats</div>
                                </div>
                            </div>
                        </div>

                        <!-- Loadout actions -->
                        <div class="lb-footer-actions" id="lbFooterActions">
                            <div class="lb-footer-left">
                                <button class="pf-btn pf-btn--sm" id="clearLoadoutBtn">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    Clear
                                </button>
                            </div>
                            <div class="lb-footer-right" id="lbOwnerActions" style="display:none;">
                                <input type="text" class="lb-name-input" id="loadoutNameInput" placeholder="Loadout name..." maxlength="40">
                                <button class="pf-btn pf-btn--primary pf-btn--sm" id="saveLoadoutBtn">Save to Profile</button>
                            </div>
                        </div>

                        <!-- Saved loadouts -->
                        <div class="lb-saved" id="lbSavedSection">
                            <div class="lb-saved-header">
                                <span class="lb-section-label">SAVED LOADOUTS</span>
                            </div>
                            <div class="lb-saved-grid" id="savedLoadoutsGrid"></div>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- Item picker modal -->
        <div class="pf-picker-overlay" id="pickerOverlay">
            <div class="pf-picker">
                <div class="pf-picker-header">
                    <span class="pf-picker-title" id="pickerTitle">Select Item</span>
                    <button class="pf-picker-close" id="pickerClose">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="pf-picker-search">
                    <input type="text" id="pickerSearch" placeholder="Search..." autocomplete="off">
                </div>
                <div class="pf-picker-items" id="pickerItems"></div>
            </div>
        </div>
    </div><!-- /pf-page-content -->

        <!-- Right Siderail Ad -->
        <aside class="ad-siderail ad-siderail--right">
            <div class="ad-siderail-sticky">
                <span class="ad-label">Ad</span>
                <div class="ad-container">
                    <ins class="adsbygoogle" style="display:block"
                         data-ad-client="ca-pub-1865737750178944" data-ad-slot="1892101209"
                         data-ad-format="auto"
                         data-full-width-responsive="true"></ins>
                    <script>try{(adsbygoogle = window.adsbygoogle || []).push({})}catch(e){}</script>
                </div>
            </div>
        </aside>

    </div><!-- /ad-page-wrapper -->
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-main">
                <div class="footer-brand">
                    <span class="footer-logo">MARATHON</span>
                    <span class="footer-logo-sub">DATABASE</span>
                </div>
                <div class="footer-nav">
                    <a href="/weapons/" class="footer-link">Weapons</a>
                    <a href="/runners/" class="footer-link">Runners</a>
                    <a href="/cores/" class="footer-link">Cores</a>
                    <a href="/implants/" class="footer-link">Implants</a>
                    <a href="/items/" class="footer-link">Items</a>
                    <a href="/mods/" class="footer-link">Mods</a>
                    <a href="/contracts/" class="footer-link">Contracts</a>
                    <a href="/weapon-skins/" class="footer-link">Skins</a>
                    <a href="/tier-lists/" class="footer-link">Tier Lists</a>
                    <a href="/loadout-builder/" class="footer-link">Loadout Builder</a>
                    <a href="/news/" class="footer-link">News</a>
                </div>
                <div class="footer-social">
                    <a href="https://x.com/MarathonDB" target="_blank" class="footer-social-link" title="X/Twitter">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href="https://discord.gg/TPhQW2aPBC" target="_blank" class="footer-social-link" title="Discord">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
                    </a>
                    <a href="mailto:Heymarathondb@Gmail.com" class="footer-social-link" title="Email">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </a>
                </div>
            </div>
            <div class="footer-legal">
                <p class="footer-disclaimer">Marathon&trade; is a trademark of Bungie, Inc. This site is not affiliated with or endorsed by Bungie.</p>
                <p class="footer-links"><a href="/pages/about.html">About</a> &middot; <a href="/pages/contact.html">Contact</a> &middot; <a href="/pages/privacy-policy.html">Privacy Policy</a> &middot; <a href="/pages/terms-and-conditions.html">Terms</a></p>
            </div>
        </div>
    </footer>

    <script src="/js/search.js"></script>
    <script src="/js/mobile-nav.js"></script>
    <script src="/js/api.js"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/data/faction-upgrades.js"></script>
    <script>
    (function() {
        'use strict';

        /* ═══════════════════════════════════════════════════════════
           CONSTANTS & CONFIG
        ═══════════════════════════════════════════════════════════ */
        const API_BASE = 'https://helpbot.marathondb.gg';
        const CORES_API  = 'https://cores.marathondb.gg';
        const IMPLANTS_API = 'https://implants.marathondb.gg';
        const MODS_API = 'https://mods.marathondb.gg';

        const RUNNER_STATS = [
            { key: 'heat_capacity',     label: 'Heat Capacity',     suffix: '' },
            { key: 'agility',           label: 'Agility',           suffix: '' },
            { key: 'loot_speed',        label: 'Loot Speed',        suffix: '' },
            { key: 'melee_damage',      label: 'Melee Damage',      suffix: '' },
            { key: 'prime_recovery',    label: 'Prime Recovery',    suffix: '' },
            { key: 'tactical_recovery', label: 'Tactical Recovery', suffix: '' },
            { key: 'self_repair_speed', label: 'Self-Repair Speed', suffix: 's', inverse: true },
            { key: 'finisher_siphon',   label: 'Finisher Siphon',   suffix: '' },
            { key: 'revive_speed',      label: 'Revive Speed',      suffix: 's', inverse: true },
            { key: 'hardware',          label: 'Hardware',          suffix: '' },
            { key: 'firewall',          label: 'Firewall',          suffix: '' },
            { key: 'fall_resistance',   label: 'Fall Resistance',   suffix: '' },
            { key: 'ping_duration',     label: 'Ping Duration',     suffix: 's' },
        ];

        const CORE_WEAPON_STATS = [
            { key: 'firepower_score', label: 'Firepower',  group: 'Firepower' },
            { key: 'damage',          label: 'Damage',     group: 'Firepower' },
            { key: 'precision',       label: 'Precision Multiplier', group: 'Firepower', suffix: 'x' },
            { key: 'rate_of_fire',    label: 'Rate of Fire', group: 'Firepower', suffix: ' RPM' },
        ];

        const TTK_STATS = [
            { key: 'ttk_no_shield',     label: 'vs No Shield' },
            { key: 'ttk_green_shield',  label: 'vs Green Shield' },
            { key: 'ttk_blue_shield',   label: 'vs Blue Shield' },
            { key: 'ttk_purple_shield', label: 'vs Purple Shield' },
        ];

        const ACCURACY_STATS = [
            { key: 'accuracy_score',       label: 'Accuracy',        group: 'Accuracy' },
            { key: 'hipfire_spread',       label: 'Hipfire Spread',  group: 'Accuracy', suffix: '°', inverse: true },
            { key: 'ads_spread',           label: 'ADS Spread',      group: 'Accuracy', suffix: '°', inverse: true },
            { key: 'crouch_spread_bonus',  label: 'Crouch Spread Bonus', group: 'Accuracy', suffix: '%' },
            { key: 'moving_inaccuracy',    label: 'Moving Inaccuracy',   group: 'Accuracy', suffix: '%', inverse: true },
        ];

        const HANDLING_STATS = [
            { key: 'handling_score', label: 'Handling',     group: 'Handling' },
            { key: 'equip_speed',    label: 'Equip Speed',  group: 'Handling', suffix: 's', inverse: true },
            { key: 'ads_speed',      label: 'ADS Speed',    group: 'Handling', suffix: 's', inverse: true },
            { key: 'weight',         label: 'Weight',       group: 'Handling', suffix: '%', inverse: true },
            { key: 'recoil',         label: 'Recoil',       group: 'Handling', suffix: '%', inverse: true },
            { key: 'aim_assist',     label: 'Aim Assist',   group: 'Handling', suffix: '°' },
            { key: 'reload_speed',   label: 'Reload Speed', group: 'Handling', suffix: 's', inverse: true },
        ];

        const RANGE_MAG_STATS = [
            { key: 'range_meters',  label: 'Range',    suffix: 'm' },
            { key: 'magazine_size', label: 'Magazine', suffix: '' },
        ];

        const FALLBACK_RUNNER_RANGES = {
            heat_capacity: { min: 30, max: 200 }, agility: { min: 3, max: 100 },
            loot_speed: { min: 1, max: 100 }, melee_damage: { min: 5, max: 120 },
            prime_recovery: { min: 1, max: 45 }, tactical_recovery: { min: 1, max: 45 },
            self_repair_speed: { min: 1, max: 30 }, finisher_siphon: { min: 0, max: 100 },
            revive_speed: { min: 1, max: 20 }, hardware: { min: 1, max: 50 },
            firewall: { min: 5, max: 200 }, fall_resistance: { min: 0, max: 100 },
            ping_duration: { min: 1, max: 10 },
        };

        const RARITY_COLORS = {
            standard: '#9ca3af', enhanced: '#4ade80', deluxe: '#60a5fa',
            superior: '#c084fc', prestige: '#fbbf24', contraband: '#f87171',
        };

        /* ═══════════════════════════════════════════════════════════
           DOM
        ═══════════════════════════════════════════════════════════ */
        const loadingEl  = document.getElementById('profileLoading');
        const errorEl    = document.getElementById('profileError');
        const errorTitle = document.getElementById('errorTitle');
        const errorText  = document.getElementById('errorText');
        const contentEl  = document.getElementById('profileContent');

        /* URL parsing */
        const params = new URLSearchParams(window.location.search);
        let userParam   = params.get('user');
        let bungieParam = params.get('bungie');
        const mockParam = params.get('mock');
        if (bungieParam && !bungieParam.includes('#') && window.location.hash) {
            bungieParam += window.location.hash;
        }
        const path = window.location.pathname;
        const bungieMatch = path.match(/^\/player-profiles\/bungie\/(.+)/);
        const userMatch   = path.match(/^\/player-profiles\/u\/(.+)/);
        if (bungieMatch && !bungieParam) {
            let raw = decodeURIComponent(bungieMatch[1].replace(/\/$/, ''));
            if (window.location.hash && !raw.includes('#')) raw += window.location.hash;
            bungieParam = raw;
        } else if (userMatch && !userParam) {
            userParam = decodeURIComponent(userMatch[1].replace(/\/$/, ''));
        }

        let _currentUser = null;
        let _isOwner = false;
        let _profile = null;

        /* ═══════════════════════════════════════════════════════════
           LOADOUT STATE
        ═══════════════════════════════════════════════════════════ */
        const cache = {
            runners: [], weapons: [], cores: [], implants: [], mods: [], items: [], shields: [],
        };
        let runnerStatRanges = { ...FALLBACK_RUNNER_RANGES };

        const loadout = {
            runner: null,       // full runner detail
            weapon: null,       // full weapon object
            mods: [null, null, null, null],
            equipment: null,
            shield: null,
            core1: null,
            core2: null,
            head: null,
            torso: null,
            legs: null,
        };

        // Runner-specific filtered data
        let compatibleCores = [];
        let compatibleImplants = { head: [], torso: [], legs: [], shield: [] };
        let weaponModSlots = [];     // available mod slot types for selected weapon
        let weaponMods = [];         // all mods for selected weapon

        /* ═══════════════════════════════════════════════════════════
           INIT
        ═══════════════════════════════════════════════════════════ */
        if (mockParam) {
            boot(getMockProfile());
        } else if (!userParam && !bungieParam) {
            // No explicit target — try to show the current user's own profile
            MDBAuth.getUser().then(me => {
                if (me && me.username) {
                    userParam = me.username;
                    initFromApi();
                } else {
                    showError('No Profile Specified', 'Please provide a username or Bungie ID to view a profile.');
                }
            });
        } else {
            initFromApi();
        }

        async function initFromApi() {
            try {
                let data;
                if (userParam) {
                    const res = await MDBAuth.getProfileByUsername(userParam);
                    if (!res.success) throw new Error(res.error || 'Profile not found');
                    data = normalizeUsernameProfile(res.data);
                } else if (bungieParam) {
                    const parsed = MDBAuth.parseBungieName(bungieParam);
                    if (parsed) {
                        const searchRes = await MDBAuth.searchPlayersExact(parsed.display_name, parsed.display_name_code);
                        if (!searchRes.success || !searchRes.data) throw new Error('Player not found');
                        const player = searchRes.data;
                        if (player.marathondb_user) {
                            const res = await MDBAuth.getProfileByUsername(player.marathondb_user.username);
                            if (!res.success) throw new Error(res.error || 'Profile not found');
                            data = normalizeUsernameProfile(res.data);
                        } else {
                            const bungieId = player.bungie_net_membership_id;
                            if (!bungieId) throw new Error('Could not resolve Bungie ID');
                            const res = await MDBAuth.getProfileByBungie(bungieId);
                            if (!res.success) throw new Error(res.error || 'Profile not found');
                            data = normalizeBungieProfile(res.data);
                        }
                    } else {
                        const res = await MDBAuth.getProfileByBungie(bungieParam);
                        if (!res.success) throw new Error(res.error || 'Profile not found');
                        data = normalizeBungieProfile(res.data);
                    }
                }
                boot(data);
            } catch (err) {
                showError('Profile Not Found', err.message || 'The requested profile could not be found.');
            }
        }

        function getMockProfile() {
            return {
                username: 'LewieJ', userId: 1, premium: true,
                createdAt: '2025-08-14T19:22:00Z',
                bungieName: 'MarathonDB.GG#1580', bungieNetId: '31374339',
                avatarUrl: 'https://www.bungie.net/img/profile/avatars/default_avatar.gif',
                hasMdb: true,
            };
        }

        function normalizeUsernameProfile(d) {
            const bi = d.bungie_identity || {};
            return {
                username: d.username, userId: d.user_id, premium: d.premium,
                createdAt: d.created_at,
                bungieName: bi.full_bungie_name || (bi.display_name ? bi.display_name + '#' + bi.display_name_code : ''),
                bungieNetId: bi.bungie_net_membership_id,
                avatarUrl: bi.avatar_path || null,
                hasMdb: true,
            };
        }

        function normalizeBungieProfile(d) {
            const bi = d.bungie_identity || {};
            const mdb = d.marathondb_user;
            return {
                username: mdb ? mdb.username : null,
                userId: mdb ? mdb.user_id : null,
                premium: mdb ? mdb.premium : false,
                createdAt: mdb ? mdb.created_at : null,
                bungieName: bi.full_bungie_name || (bi.display_name ? bi.display_name + '#' + bi.display_name_code : ''),
                bungieNetId: bi.bungie_net_membership_id,
                avatarUrl: bi.avatar_path || null,
                hasMdb: !!mdb,
            };
        }

        async function boot(profile) {
            _profile = profile;

            try {
                _currentUser = await MDBAuth.getUser();
                if (_currentUser && profile.userId && _currentUser.user_id === profile.userId) {
                    _isOwner = true;
                }
            } catch {}

            renderHeader(profile);
            setupTabs();
            setupShareBtn(profile);
            initFactionUpgrades();

            loadingEl.style.display = 'none';
            contentEl.style.display = '';

            document.title = (profile.username || profile.bungieName || 'Player') + ' — Profile | MarathonDB';

            // Load game data for loadout builder
            await loadGameData();
            renderRunnerSelector();
            setupLoadoutBuilder();
        }

        /* ═══════════════════════════════════════════════════════════
           LOAD GAME DATA
        ═══════════════════════════════════════════════════════════ */
        async function loadGameData() {
            try {
                const [runners, weapons, coresResp, implantsResp, items, rangesResp] = await Promise.all([
                    MarathonAPI.getRunners().catch(() => []),
                    MarathonAPI.getWeapons().catch(() => []),
                    MarathonAPI.getCores().catch(() => null),
                    MarathonAPI.getImplants().catch(() => null),
                    MarathonAPI.getAllItems().catch(() => []),
                    MarathonAPI.getRunnerStatRanges().catch(() => null),
                ]);

                cache.runners = Array.isArray(runners) ? runners : (runners?.data || []);
                cache.weapons = Array.isArray(weapons) ? weapons : (weapons?.data || []);

                const coresRaw = coresResp?.data || coresResp || [];
                cache.cores = Array.isArray(coresRaw) ? coresRaw : [];

                const impRaw = implantsResp?.data || implantsResp || [];
                cache.implants = (Array.isArray(impRaw) ? impRaw : []).map(i => ({
                    ...i,
                    icon_url: i.icon_url && !i.icon_url.startsWith('http')
                        ? IMPLANTS_API + '/' + i.icon_url
                        : i.icon_url,
                }));

                cache.items = Array.isArray(items) ? items : (items?.data || []);
                cache.shields = cache.implants.filter(i => i.slot === 'shield');

                if (rangesResp) {
                    const rd = rangesResp.data || rangesResp;
                    if (typeof rd === 'object') Object.assign(runnerStatRanges, rd);
                }
            } catch (e) {
                console.error('Failed to load game data:', e);
            }
        }

        /* ═══════════════════════════════════════════════════════════
           RENDER HEADER
        ═══════════════════════════════════════════════════════════ */
        function renderHeader(p) {
            const avatarEl = document.getElementById('pfAvatar');
            const placeholderEl = document.getElementById('pfAvatarPlaceholder');
            if (p.avatarUrl) { avatarEl.src = p.avatarUrl; avatarEl.style.display = ''; placeholderEl.style.display = 'none'; }
            else { avatarEl.style.display = 'none'; placeholderEl.style.display = ''; }

            document.getElementById('pfUsername').textContent = p.username || p.bungieName || 'Unknown Player';
            const sub = [];
            if (p.bungieName && p.username) sub.push(p.bungieName);
            if (p.createdAt) sub.push('Joined ' + new Date(p.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'short' }));
            document.getElementById('pfSubtitle').textContent = sub.join('  ·  ');

            let badgesHtml = '';
            if (p.premium) badgesHtml += '<span class="pf-badge pf-badge--premium">Premium</span>';
            if (p.userId && p.userId <= 100) badgesHtml += '<span class="pf-badge pf-badge--early">Early Adopter</span>';
            document.getElementById('pfBadges').innerHTML = badgesHtml;
        }

        /* ═══════════════════════════════════════════════════════════
           RUNNER SELECTOR BAR
        ═══════════════════════════════════════════════════════════ */
        function renderRunnerSelector() {
            const bar = document.getElementById('runnerSelectorBar');
            if (!cache.runners.length) {
                bar.innerHTML = '<span class="lb-runner-bar-loading">No runners found</span>';
                return;
            }
            bar.innerHTML = cache.runners.map(r => {
                const portrait = API_BASE + '/assets/runners/' + r.slug + '-150x230.png';
                return '<button class="lb-runner-btn" data-slug="' + esc(r.slug) + '">' +
                    '<img class="lb-runner-btn-img" src="' + portrait + '" alt="' + esc(r.name) + '" loading="lazy" onerror="this.style.display=\'none\'">' +
                    '<span class="lb-runner-btn-name">' + esc(r.name) + '</span>' +
                    '</button>';
            }).join('');

            bar.querySelectorAll('.lb-runner-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const slug = btn.dataset.slug;
                    const runner = cache.runners.find(r => r.slug === slug);
                    if (runner) selectRunner(runner);
                });
            });
        }

        /* ═══════════════════════════════════════════════════════════
           SELECT RUNNER
        ═══════════════════════════════════════════════════════════ */
        async function selectRunner(runner) {
            // Reset loadout
            loadout.weapon = null;
            loadout.mods = [null, null, null, null];
            loadout.equipment = null;
            loadout.shield = null;
            loadout.core1 = null;
            loadout.core2 = null;
            loadout.head = null;
            loadout.torso = null;
            loadout.legs = null;
            weaponModSlots = [];
            weaponMods = [];

            // Active state on selector
            document.querySelectorAll('.lb-runner-btn').forEach(b => b.classList.toggle('active', b.dataset.slug === runner.slug));

            // Show active loadout
            document.getElementById('lbEmpty').style.display = 'none';
            document.getElementById('lbActive').style.display = '';

            // Set hero image
            document.getElementById('lbHeroImg').src = API_BASE + '/assets/runners/' + runner.slug + '/hero.webp';
            document.getElementById('lbHeroImg').alt = runner.name;
            document.getElementById('lbRunnerName').textContent = (runner.name || '').toUpperCase();
            document.getElementById('lbRunnerRole').textContent = runner.role || '';
            document.getElementById('lbRunnerDesc').textContent = runner.description || '';

            // Fetch full detail + cores
            try {
                const [detail, coresResp] = await Promise.all([
                    MarathonAPI.getRunnerBySlug(runner.slug).catch(() => null),
                    MarathonAPI.getCoresByRunner(runner.slug).catch(() => null),
                ]);

                const data = detail?.data || detail;
                if (data) loadout.runner = data;
                else loadout.runner = runner;

                // Merge runner-specific + universal cores
                const runnerCores = coresResp?.data || coresResp || [];
                const universalCores = cache.cores.filter(c => c.runner_type === 'all');
                const seen = new Set();
                compatibleCores = [];
                for (const c of [...(Array.isArray(runnerCores) ? runnerCores : []), ...universalCores]) {
                    if (!seen.has(c.slug)) { seen.add(c.slug); compatibleCores.push(c); }
                }

                // Implants by slot
                compatibleImplants = {
                    head:   cache.implants.filter(i => i.slot === 'head'),
                    torso:  cache.implants.filter(i => i.slot === 'torso'),
                    legs:   cache.implants.filter(i => i.slot === 'legs'),
                    shield: cache.implants.filter(i => i.slot === 'shield'),
                };
            } catch (e) {
                console.error('Failed to load runner detail:', e);
                loadout.runner = runner;
            }

            renderAbilities();
            renderRunnerStats();
            clearAllSlotUIs();
            clearWeaponStats();

            // Enable mod slots? No — only when weapon is picked
            updateModSlotState();
        }

        /* ═══════════════════════════════════════════════════════════
           RENDER: ABILITIES
        ═══════════════════════════════════════════════════════════ */
        function renderAbilities() {
            const el = document.getElementById('lbAbilities');
            const abilities = loadout.runner?.abilities || [];
            if (!abilities.length) { el.innerHTML = ''; return; }
            el.innerHTML = abilities.map(a => {
                const type = typeof a === 'string' ? '' : (a.ability_type || '').toUpperCase();
                const name = typeof a === 'string' ? a : (a.name || '');
                return '<div class="lb-ability"><span class="lb-ability-type">' + esc(type) + '</span><span class="lb-ability-name">' + esc(name) + '</span></div>';
            }).join('');
        }

        /* ═══════════════════════════════════════════════════════════
           RENDER: RUNNER STATS
        ═══════════════════════════════════════════════════════════ */
        function toSnakeCase(str) {
            return str.replace(/([A-Z])/g, '_$1').toLowerCase();
        }

        function getRunnerStatValue(key) {
            const stats = loadout.runner?.stats;
            if (!stats) return null;
            if (stats[key] !== undefined) return stats[key];
            // Try camelCase
            for (const [k, v] of Object.entries(stats)) {
                if (toSnakeCase(k) === key) return v;
            }
            return null;
        }

        function getEquipDelta(statKey) {
            let total = 0;
            for (const slot of ['shield', 'head', 'torso', 'legs']) {
                const item = loadout[slot];
                if (item && item.stats) {
                    for (const s of item.stats) {
                        if (s.stat_name === statKey || toSnakeCase(s.stat_name || '') === statKey) {
                            total += (s.stat_value || 0);
                        }
                    }
                }
            }
            return total;
        }

        function renderRunnerStats() {
            const el = document.getElementById('lbRunnerStats');
            if (!loadout.runner) { el.innerHTML = ''; return; }

            let html = '';
            for (const stat of RUNNER_STATS) {
                const base = getRunnerStatValue(stat.key);
                if (base == null) continue;
                const delta = getEquipDelta(stat.key);
                const modified = base + delta;
                const maxVal = (runnerStatRanges[stat.key] || {}).max || 100;

                let pct;
                if (stat.inverse) {
                    pct = Math.max(0, Math.min(100, ((maxVal - modified) / maxVal) * 100));
                } else {
                    pct = Math.max(0, Math.min(100, (modified / maxVal) * 100));
                }

                let deltaHtml = '';
                if (delta !== 0) {
                    const isGood = stat.inverse ? (delta < 0) : (delta > 0);
                    const cls = isGood ? 'lb-delta--good' : 'lb-delta--bad';
                    const sign = delta > 0 ? '+' : '';
                    deltaHtml = '<span class="lb-stat-delta ' + cls + '">' + sign + delta + '</span>';
                }

                html += '<div class="lb-stat-row">' +
                    '<span class="lb-stat-label">' + esc(stat.label) + '</span>' +
                    '<div class="lb-stat-bar-wrap"><div class="lb-stat-bar" style="width:' + pct + '%"></div></div>' +
                    '<span class="lb-stat-value">' + modified + (stat.suffix || '') + '</span>' +
                    deltaHtml +
                    '</div>';
            }
            el.innerHTML = html;
        }

        /* ═══════════════════════════════════════════════════════════
           SELECT WEAPON
        ═══════════════════════════════════════════════════════════ */
        async function selectWeapon(weapon) {
            loadout.weapon = weapon;
            loadout.mods = [null, null, null, null];

            // Update weapon slot UI
            const slotEl = document.getElementById('slotWeapon');
            const imgEl = document.getElementById('lbWeaponImg');
            const labelEl = slotEl.querySelector('.lb-weapon-slot-label');
            imgEl.src = API_BASE + '/assets/weapons/' + weapon.slug + '-800x600.png';
            imgEl.style.display = '';
            imgEl.alt = weapon.name;
            labelEl.textContent = weapon.name;

            // Fetch mods for this weapon
            try {
                const [modsResp, slotsResp] = await Promise.all([
                    MarathonAPI.getModsForWeapon(weapon.slug).catch(() => null),
                    MarathonAPI.getModSlotsForWeapon(weapon.slug).catch(() => null),
                ]);
                weaponMods = modsResp?.data || modsResp || [];
                if (!Array.isArray(weaponMods)) weaponMods = [];

                const slotsData = slotsResp?.data || slotsResp;
                weaponModSlots = Array.isArray(slotsData) ? slotsData : (slotsData?.slots || []);
                if (!Array.isArray(weaponModSlots)) weaponModSlots = [];
            } catch { weaponMods = []; weaponModSlots = []; }

            updateModSlotState();
            clearModSlotUIs();
            renderWeaponStats();
        }

        function updateModSlotState() {
            for (let i = 0; i < 4; i++) {
                const btn = document.getElementById('slotMod' + (i + 1));
                if (!btn) continue;
                const hasSlot = loadout.weapon && i < weaponModSlots.length;
                btn.disabled = !hasSlot;
                btn.classList.toggle('lb-slot--disabled', !hasSlot);
                if (hasSlot) {
                    const slotType = weaponModSlots[i];
                    btn.dataset.modSlotType = typeof slotType === 'string' ? slotType : (slotType?.slot_type || '');
                }
            }
        }

        /* ═══════════════════════════════════════════════════════════
           RENDER: WEAPON STATS
        ═══════════════════════════════════════════════════════════ */
        function getModDelta(statKey) {
            let total = 0;
            for (const mod of loadout.mods) {
                if (!mod) continue;
                const effects = mod.effects || [];
                for (const e of effects) {
                    const eKey = e.stat_key || e.stat_name || '';
                    if (eKey === statKey) total += (e.delta || e.stat_modifier_value || 0);
                }
            }
            return total;
        }

        function renderWeaponStats() {
            const el = document.getElementById('lbWeaponStats');
            const w = loadout.weapon;
            if (!w) { el.innerHTML = '<div class="lb-ws-empty">Select a weapon to view stats</div>'; return; }

            let html = '';

            // Firepower section
            html += renderStatSection('Firepower', w.firepower_score, CORE_WEAPON_STATS, w);

            // TTK
            const hasTTK = TTK_STATS.some(s => w[s.key] != null);
            if (hasTTK) {
                html += '<div class="lb-ws-section"><div class="lb-ws-section-header"><span>TTK</span></div>';
                for (const s of TTK_STATS) {
                    const val = w[s.key];
                    if (val == null) continue;
                    const isGreen = s.key === 'ttk_green_shield';
                    const isBlue = s.key === 'ttk_blue_shield';
                    const isPurple = s.key === 'ttk_purple_shield';
                    let cls = '';
                    if (isGreen) cls = ' lb-ws-ttk--green';
                    else if (isBlue) cls = ' lb-ws-ttk--blue';
                    else if (isPurple) cls = ' lb-ws-ttk--purple';
                    html += '<div class="lb-ws-row' + cls + '"><span class="lb-ws-label">' + esc(s.label) + '</span><span class="lb-ws-value">' + val + 's</span></div>';
                }
                html += '</div>';
            }

            // Accuracy section
            html += renderStatSection('Accuracy', w.accuracy_score, ACCURACY_STATS, w);

            // Handling section
            html += renderStatSection('Handling', w.handling_score, HANDLING_STATS, w);

            // Range & Magazine
            html += '<div class="lb-ws-section">';
            for (const s of RANGE_MAG_STATS) {
                const base = w[s.key];
                if (base == null) continue;
                const delta = getModDelta(s.key);
                const modified = base + delta;
                html += statRowHtml(s.label, modified, s.suffix || '', delta);
            }
            html += '</div>';

            el.innerHTML = html;
        }

        function renderStatSection(title, score, stats, w) {
            let html = '<div class="lb-ws-section"><div class="lb-ws-section-header">';
            html += '<span>' + esc(title) + '</span>';
            if (score != null) {
                const delta = getModDelta(stats[0]?.key);
                const modScore = score + delta;
                html += '<span class="lb-ws-section-score">' + modScore.toFixed(1) + '</span>';
            }
            html += '</div>';
            // Skip first stat (the score) for details
            for (let i = 1; i < stats.length; i++) {
                const s = stats[i];
                const base = w[s.key];
                if (base == null) continue;
                const delta = getModDelta(s.key);
                const modified = base + delta;
                html += statRowHtml(s.label, modified, s.suffix || '', delta, s.inverse);
            }
            html += '</div>';
            return html;
        }

        function statRowHtml(label, value, suffix, delta, inverse) {
            let deltaHtml = '';
            if (delta && delta !== 0) {
                const isGood = inverse ? (delta < 0) : (delta > 0);
                const cls = isGood ? 'lb-delta--good' : 'lb-delta--bad';
                const sign = delta > 0 ? '+' : '';
                deltaHtml = ' <span class="lb-stat-delta ' + cls + '">' + sign + delta + suffix + '</span>';
            }
            const display = typeof value === 'number' ? (Number.isInteger(value) ? value : value.toFixed(1)) : value;
            return '<div class="lb-ws-row"><span class="lb-ws-label">' + esc(label) + '</span><span class="lb-ws-value">' + display + suffix + deltaHtml + '</span></div>';
        }

        function clearWeaponStats() {
            document.getElementById('lbWeaponStats').innerHTML = '<div class="lb-ws-empty">Select a weapon to view stats</div>';
            const imgEl = document.getElementById('lbWeaponImg');
            imgEl.style.display = 'none';
            imgEl.src = '';
            document.querySelector('.lb-weapon-slot-label').textContent = 'Select Weapon';
        }

        /* ═══════════════════════════════════════════════════════════
           SLOT UI MANAGEMENT
        ═══════════════════════════════════════════════════════════ */
        function setSlotUI(slotId, item, type) {
            const iconEl = document.getElementById(slotId + 'Icon');
            if (!iconEl) return;
            if (!item) {
                iconEl.innerHTML = '';
                iconEl.closest('.lb-slot')?.classList.remove('lb-slot--filled');
                return;
            }
            const url = getItemIconUrl(item, type);
            const rarityClr = RARITY_COLORS[item.rarity] || '';
            iconEl.innerHTML = '<img src="' + url + '" alt="' + esc(item.name || '') + '" onerror="this.style.display=\'none\'">';
            const slot = iconEl.closest('.lb-slot');
            if (slot) {
                slot.classList.add('lb-slot--filled');
                slot.style.borderColor = rarityClr || '';
            }
        }

        function getItemIconUrl(item, type) {
            if (item.icon_url) {
                if (item.icon_url.startsWith('http')) return item.icon_url;
                return IMPLANTS_API + '/' + item.icon_url;
            }
            if (item.icon_url_webp) return item.icon_url_webp;
            switch (type) {
                case 'weapon': return API_BASE + '/assets/weapons/' + item.slug + '-180x135.png';
                case 'core':   return CORES_API + '/assets/items/cores/' + item.slug + '-72x72.png';
                case 'implant':
                case 'shield': return IMPLANTS_API + '/assets/items/implants/' + item.slug + '-72x72.png';
                case 'mod':    return MODS_API + '/images/' + item.slug + '.webp';
                default:       return API_BASE + '/assets/items/equipment/' + (item.slug || 'placeholder') + '-72x72.png';
            }
        }

        function clearAllSlotUIs() {
            ['slotEquipment', 'slotShield', 'slotCore1', 'slotCore2', 'slotHead', 'slotTorso', 'slotLegs'].forEach(id => {
                const iconEl = document.getElementById(id + 'Icon');
                if (iconEl) iconEl.innerHTML = '';
                const slot = document.getElementById(id);
                if (slot) { slot.classList.remove('lb-slot--filled'); slot.style.borderColor = ''; }
            });
            clearModSlotUIs();
            clearWeaponStats();
        }

        function clearModSlotUIs() {
            for (let i = 1; i <= 4; i++) {
                const iconEl = document.getElementById('slotMod' + i + 'Icon');
                if (iconEl) iconEl.innerHTML = '';
                const slot = document.getElementById('slotMod' + i);
                if (slot) { slot.classList.remove('lb-slot--filled'); slot.style.borderColor = ''; }
            }
        }

        /* ═══════════════════════════════════════════════════════════
           ITEM PICKER
        ═══════════════════════════════════════════════════════════ */
        let _pickerSlot = null;

        function openPicker(slot, items, title, onSelect) {
            _pickerSlot = slot;
            const overlay = document.getElementById('pickerOverlay');
            const titleEl = document.getElementById('pickerTitle');
            const searchEl = document.getElementById('pickerSearch');
            const itemsEl = document.getElementById('pickerItems');
            titleEl.textContent = title;
            searchEl.value = '';
            overlay.classList.add('active');

            renderPickerItems(items, itemsEl, onSelect);

            searchEl.oninput = () => {
                const q = searchEl.value.toLowerCase();
                const filtered = items.filter(i => (i.name || '').toLowerCase().includes(q));
                renderPickerItems(filtered, itemsEl, onSelect);
            };
            searchEl.focus();
        }

        function renderPickerItems(items, container, onSelect) {
            container.innerHTML = items.map(i => {
                const icon = i._iconUrl || '';
                const rarity = i.rarity || '';
                const rarityClr = RARITY_COLORS[rarity] || '';
                const meta = i._meta || '';
                return '<div class="pf-picker-item" data-slug="' + esc(i.slug || i.name || '') + '"' +
                    (rarityClr ? ' style="border-left:3px solid ' + rarityClr + '"' : '') + '>' +
                    (icon ? '<img class="pf-picker-item-icon" src="' + icon + '" alt="" onerror="this.style.display=\'none\'">' : '') +
                    '<div><div class="pf-picker-item-name">' + esc(i.name || '') + '</div>' +
                    (meta ? '<div class="pf-picker-item-meta">' + esc(meta) + '</div>' : '') +
                    '</div></div>';
            }).join('') || '<div class="pf-picker-empty">No items found</div>';

            container.querySelectorAll('.pf-picker-item').forEach(el => {
                el.addEventListener('click', () => {
                    const slug = el.dataset.slug;
                    const item = items.find(i => (i.slug || i.name) === slug);
                    if (item) onSelect(item);
                    closePicker();
                });
            });
        }

        function closePicker() {
            document.getElementById('pickerOverlay').classList.remove('active');
        }

        /* ═══════════════════════════════════════════════════════════
           SETUP LOADOUT BUILDER (slot click handlers)
        ═══════════════════════════════════════════════════════════ */
        function setupLoadoutBuilder() {
            // Owner actions
            if (_isOwner) {
                document.getElementById('lbOwnerActions').style.display = '';
            }

            // Picker close
            document.getElementById('pickerClose').addEventListener('click', closePicker);
            document.getElementById('pickerOverlay').addEventListener('click', e => {
                if (e.target === e.currentTarget) closePicker();
            });

            // Clear button
            document.getElementById('clearLoadoutBtn').addEventListener('click', () => {
                if (loadout.runner) selectRunner(loadout.runner);
            });

            // --- Slot handlers ---

            // Weapon
            document.getElementById('slotWeapon').addEventListener('click', () => {
                if (!loadout.runner) return;
                const items = cache.weapons.map(w => ({
                    ...w, _iconUrl: API_BASE + '/assets/weapons/' + w.slug + '-180x135.png',
                    _meta: w.category || w.weapon_type || '',
                }));
                openPicker('weapon', items, 'Select Weapon', (item) => {
                    selectWeapon(item);
                });
            });

            // Mod slots
            for (let i = 1; i <= 4; i++) {
                const idx = i - 1;
                document.getElementById('slotMod' + i).addEventListener('click', () => {
                    if (!loadout.weapon || idx >= weaponModSlots.length) return;
                    const slotType = typeof weaponModSlots[idx] === 'string' ? weaponModSlots[idx] : (weaponModSlots[idx]?.slot_type || '');
                    const filtered = weaponMods.filter(m => {
                        const mt = m.slot_type || '';
                        return !slotType || mt === slotType;
                    }).map(m => ({
                        ...m, _iconUrl: MODS_API + '/images/' + m.slug + '.webp',
                        _meta: (m.slot_type || '') + (m.rarity ? ' · ' + m.rarity : ''),
                    }));
                    openPicker('mod' + i, filtered, 'Select ' + (slotType || 'Mod'), (item) => {
                        loadout.mods[idx] = item;
                        setSlotUI('slotMod' + i, item, 'mod');
                        renderWeaponStats();
                    });
                });
            }

            // Equipment
            document.getElementById('slotEquipment').addEventListener('click', () => {
                if (!loadout.runner) return;
                const equipItems = cache.items.filter(i => {
                    const t = (i.type || i.item_type || '').toLowerCase();
                    return t.includes('grenade') || t.includes('tactical') || t.includes('equipment') || t.includes('consumable');
                }).map(i => ({
                    ...i, _iconUrl: getItemIconUrl(i, 'equipment'),
                    _meta: i.type || i.item_type || '',
                }));
                openPicker('equipment', equipItems, 'Select Equipment', (item) => {
                    loadout.equipment = item;
                    setSlotUI('slotEquipment', item, 'equipment');
                });
            });

            // Shield
            document.getElementById('slotShield').addEventListener('click', () => {
                if (!loadout.runner) return;
                const items = compatibleImplants.shield.map(i => ({
                    ...i, _iconUrl: getItemIconUrl(i, 'shield'),
                    _meta: (i.rarity || '') + (i.unique_trait_description ? ' · ' + i.unique_trait_description.slice(0, 40) : ''),
                }));
                openPicker('shield', items, 'Select Shield', (item) => {
                    loadout.shield = item;
                    setSlotUI('slotShield', item, 'shield');
                    renderRunnerStats();
                });
            });

            // Cores
            document.getElementById('slotCore1').addEventListener('click', () => {
                if (!loadout.runner) return;
                const items = compatibleCores.filter(c => !loadout.core2 || c.slug !== loadout.core2.slug).map(c => ({
                    ...c, _iconUrl: CORES_API + '/assets/items/cores/' + c.slug + '-72x72.png',
                    _meta: (c.rarity || '') + ' · ' + (c.trigger || ''),
                }));
                openPicker('core1', items, 'Select Core 1', (item) => {
                    loadout.core1 = item;
                    setSlotUI('slotCore1', item, 'core');
                });
            });
            document.getElementById('slotCore2').addEventListener('click', () => {
                if (!loadout.runner) return;
                const items = compatibleCores.filter(c => !loadout.core1 || c.slug !== loadout.core1.slug).map(c => ({
                    ...c, _iconUrl: CORES_API + '/assets/items/cores/' + c.slug + '-72x72.png',
                    _meta: (c.rarity || '') + ' · ' + (c.trigger || ''),
                }));
                openPicker('core2', items, 'Select Core 2', (item) => {
                    loadout.core2 = item;
                    setSlotUI('slotCore2', item, 'core');
                });
            });

            // Implants
            ['head', 'torso', 'legs'].forEach(slot => {
                const capSlot = slot.charAt(0).toUpperCase() + slot.slice(1);
                document.getElementById('slot' + capSlot).addEventListener('click', () => {
                    if (!loadout.runner) return;
                    const items = (compatibleImplants[slot] || []).map(i => ({
                        ...i, _iconUrl: getItemIconUrl(i, 'implant'),
                        _meta: (i.rarity || '') + (i.unique_trait_description ? ' · ' + i.unique_trait_description.slice(0, 40) : ''),
                    }));
                    openPicker(slot, items, 'Select ' + capSlot + ' Implant', (item) => {
                        loadout[slot] = item;
                        setSlotUI('slot' + capSlot, item, 'implant');
                        renderRunnerStats();
                    });
                });
            });

            // Save button
            document.getElementById('saveLoadoutBtn')?.addEventListener('click', saveCurrentLoadout);

            // Render saved loadouts
            renderSavedLoadouts();
        }

        /* ═══════════════════════════════════════════════════════════
           SAVE / LOAD LOADOUTS (localStorage for now)
        ═══════════════════════════════════════════════════════════ */
        function getStorageKey() {
            return 'mdb_profile_loadouts_' + (_profile?.username || _profile?.bungieNetId || 'anon');
        }

        function getSavedLoadouts() {
            try { return JSON.parse(localStorage.getItem(getStorageKey()) || '[]'); } catch { return []; }
        }

        function saveCurrentLoadout() {
            if (!loadout.runner) return;
            const name = document.getElementById('loadoutNameInput').value.trim() || 'Untitled Loadout';
            const entry = {
                id: Date.now(),
                name: name,
                runner: loadout.runner?.slug || null,
                weapon: loadout.weapon?.slug || null,
                mods: loadout.mods.map(m => m?.slug || null),
                equipment: loadout.equipment?.slug || null,
                shield: loadout.shield?.slug || null,
                core1: loadout.core1?.slug || null,
                core2: loadout.core2?.slug || null,
                head: loadout.head?.slug || null,
                torso: loadout.torso?.slug || null,
                legs: loadout.legs?.slug || null,
            };
            const saved = getSavedLoadouts();
            saved.push(entry);
            localStorage.setItem(getStorageKey(), JSON.stringify(saved));
            document.getElementById('loadoutNameInput').value = '';
            renderSavedLoadouts();
        }

        function renderSavedLoadouts() {
            const grid = document.getElementById('savedLoadoutsGrid');
            const saved = getSavedLoadouts();
            if (!saved.length) {
                grid.innerHTML = '<div class="lb-saved-empty">No saved loadouts yet</div>';
                return;
            }
            grid.innerHTML = saved.map(l => {
                const runnerName = cache.runners.find(r => r.slug === l.runner)?.name || l.runner || '—';
                const weaponName = cache.weapons.find(w => w.slug === l.weapon)?.name || l.weapon || '—';
                return '<div class="lb-saved-card" data-loadout-id="' + l.id + '">' +
                    '<div class="lb-saved-card-name">' + esc(l.name) + '</div>' +
                    '<div class="lb-saved-card-detail">' + esc(runnerName) + ' · ' + esc(weaponName) + '</div>' +
                    '<button class="lb-saved-card-delete" data-delete-id="' + l.id + '" title="Delete">&times;</button>' +
                    '</div>';
            }).join('');

            // Load click
            grid.querySelectorAll('.lb-saved-card').forEach(card => {
                card.addEventListener('click', (e) => {
                    if (e.target.closest('.lb-saved-card-delete')) return;
                    const id = Number(card.dataset.loadoutId);
                    const entry = saved.find(l => l.id === id);
                    if (entry) hydrateSavedLoadout(entry);
                });
            });

            // Delete click
            grid.querySelectorAll('.lb-saved-card-delete').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const id = Number(btn.dataset.deleteId);
                    const filtered = saved.filter(l => l.id !== id);
                    localStorage.setItem(getStorageKey(), JSON.stringify(filtered));
                    renderSavedLoadouts();
                });
            });
        }

        async function hydrateSavedLoadout(entry) {
            // Select runner first
            const runner = cache.runners.find(r => r.slug === entry.runner);
            if (runner) {
                await selectRunner(runner);

                // Set weapon
                if (entry.weapon) {
                    const weapon = cache.weapons.find(w => w.slug === entry.weapon);
                    if (weapon) await selectWeapon(weapon);
                }

                // Set mods
                if (entry.mods) {
                    for (let i = 0; i < entry.mods.length; i++) {
                        if (entry.mods[i]) {
                            const mod = weaponMods.find(m => m.slug === entry.mods[i]);
                            if (mod) {
                                loadout.mods[i] = mod;
                                setSlotUI('slotMod' + (i + 1), mod, 'mod');
                            }
                        }
                    }
                    renderWeaponStats();
                }

                // Set equipment & shield & cores & implants
                if (entry.shield) {
                    const item = compatibleImplants.shield.find(i => i.slug === entry.shield);
                    if (item) { loadout.shield = item; setSlotUI('slotShield', item, 'shield'); }
                }
                if (entry.core1) {
                    const item = compatibleCores.find(c => c.slug === entry.core1);
                    if (item) { loadout.core1 = item; setSlotUI('slotCore1', item, 'core'); }
                }
                if (entry.core2) {
                    const item = compatibleCores.find(c => c.slug === entry.core2);
                    if (item) { loadout.core2 = item; setSlotUI('slotCore2', item, 'core'); }
                }
                for (const slot of ['head', 'torso', 'legs']) {
                    if (entry[slot]) {
                        const item = (compatibleImplants[slot] || []).find(i => i.slug === entry[slot]);
                        if (item) {
                            loadout[slot] = item;
                            const cap = slot.charAt(0).toUpperCase() + slot.slice(1);
                            setSlotUI('slot' + cap, item, 'implant');
                        }
                    }
                }
                renderRunnerStats();
            }
        }

        /* ═══════════════════════════════════════════════════════════
           FACTION UPGRADES
        ═══════════════════════════════════════════════════════════ */
        const ACCOUNTS_API = 'https://accounts.marathondb.gg';
        const FACTION_LIST = [
            { slug: 'cyberacme',  name: 'CyberAcme',  color: '#01d838' },
            { slug: 'nucaloric',  name: 'NuCaloric',  color: '#ff125d' },
            { slug: 'traxus',     name: 'Traxus',     color: '#ff7300' },
            { slug: 'mida',       name: 'MIDA',       color: '#be72e4' },
            { slug: 'arachne',    name: 'Arachne',    color: '#e40b0d' },
            { slug: 'sekiguchi',  name: 'Sekiguchi',  color: '#cfb72f' },
        ];
        const CAT_LABELS = { inventory:'Inventory', 'function':'Function', armory:'Armory', stat:'Stat' };
        let _fuFaction = 'cyberacme';
        let _fuUserData = { upgrades: [], capstones: [] };

        function initFactionUpgrades() {
            renderFactionBar();
            loadFactionUpgrades(_fuFaction);
        }

        function renderFactionBar() {
            const bar = document.getElementById('fuFactionBar');
            bar.innerHTML = FACTION_LIST.map(f => {
                const data = window.FACTION_UPGRADES?.[f.slug];
                const disabled = !data;
                return `<button class="fu-faction-btn${f.slug === _fuFaction ? ' active' : ''}${disabled ? ' disabled' : ''}"
                    data-faction="${f.slug}" style="--fc:${f.color}"${disabled ? ' disabled' : ''}>
                    <img class="fu-faction-btn-icon" src="https://helpbot.marathondb.gg/assets/items/reputations/${f.slug}-200x200.png" alt="" width="24" height="24">
                    ${esc(f.name)}
                </button>`;
            }).join('');
            bar.querySelectorAll('.fu-faction-btn:not(.disabled)').forEach(btn => {
                btn.addEventListener('click', () => {
                    _fuFaction = btn.dataset.faction;
                    bar.querySelectorAll('.fu-faction-btn').forEach(b => b.classList.toggle('active', b === btn));
                    loadFactionUpgrades(_fuFaction);
                });
            });
        }

        async function loadFactionUpgrades(factionSlug) {
            const def = window.FACTION_UPGRADES?.[factionSlug];
            if (!def) return;
            _fuUserData = { upgrades: [], capstones: [] };
            if (_profile?.userId) {
                try {
                    const res = await fetch(`${ACCOUNTS_API}/upgrades/${factionSlug}?user_id=${_profile.userId}`, { credentials: 'include' });
                    if (res.ok) {
                        const j = await res.json();
                        if (j.success) _fuUserData = j.data;
                    }
                } catch {}
            }
            renderAll(def);
        }

        function renderAll(def) {
            renderFactionProgress(def);
            renderUpgradesList(def);
            renderCapstones(def);
        }

        function isLevelUnlocked(slug, level) {
            return _fuUserData.upgrades.some(u => u.upgrade_slug === slug && u.level === level);
        }
        function isCapstoneUnlocked(rank) {
            return _fuUserData.capstones.includes(rank);
        }

        // Flatten all upgrade levels into a single sorted list by rank
        function buildSortedItems(def) {
            const items = [];
            for (const u of def.upgrades) {
                for (const lv of u.levels) {
                    items.push({ upgrade: u, level: lv });
                }
            }
            items.sort((a, b) => {
                const ra = typeof a.level.rank === 'number' ? a.level.rank : 9999;
                const rb = typeof b.level.rank === 'number' ? b.level.rank : 9999;
                return ra - rb || a.upgrade.name.localeCompare(b.upgrade.name);
            });
            return items;
        }

        function countUnlocked(def) {
            let t = 0;
            for (const u of def.upgrades) for (const lv of u.levels) if (isLevelUnlocked(u.slug, lv.level)) t++;
            return t;
        }
        function countTotal(def) {
            let t = 0;
            for (const u of def.upgrades) t += u.levels.length;
            return t;
        }

        function renderFactionProgress(def) {
            const el = document.getElementById('fuProgress');
            const unlocked = countUnlocked(def);
            const total = countTotal(def);
            const capsUnlocked = _fuUserData.capstones.length;
            const capsTotal = def.capstones.length;
            const pct = total > 0 ? Math.round((unlocked / total) * 100) : 0;
            el.innerHTML = `
                <div class="fu-progress-card" style="--fc:${def.color}">
                    <div class="fu-progress-top">
                        <div class="fu-progress-title">${esc(def.name)} Upgrades</div>
                        <div class="fu-progress-stats">
                            <span class="fu-progress-stat"><span class="fu-progress-stat-val">${unlocked}</span> / ${total} upgrades</span>
                            <span class="fu-progress-stat"><span class="fu-progress-stat-val">${capsUnlocked}</span> / ${capsTotal} capstones</span>
                            <span class="fu-progress-pct">${pct}%</span>
                        </div>
                    </div>
                    <div class="fu-progress-bar">
                        <div class="fu-progress-fill" style="width:${pct}%"></div>
                    </div>
                </div>`;
        }

        function renderUpgradesList(def) {
            const el = document.getElementById('fuUpgradesList');
            const sorted = buildSortedItems(def);

            // Group by rank for visual sections
            const rankGroups = [];
            let currentRank = -1;
            for (const item of sorted) {
                if (item.level.rank !== currentRank) {
                    currentRank = item.level.rank;
                    rankGroups.push({ rank: currentRank, items: [] });
                }
                rankGroups[rankGroups.length - 1].items.push(item);
            }

            el.innerHTML = `
                <div class="fu-table">
                    <div class="fu-table-head">
                        <span class="fu-th fu-th-check"></span>
                        <span class="fu-th fu-th-rank">Required Faction Rank</span>
                        <span class="fu-th fu-th-name">Upgrade</span>
                        <span class="fu-th fu-th-cat">Type</span>
                        <span class="fu-th fu-th-effect">Effect</span>
                        <span class="fu-th fu-th-cost">Cost</span>
                    </div>
                    <div class="fu-table-body">
                        ${rankGroups.map(rg => rg.items.map((item, idx) => renderUpgradeRow(item, def, idx === 0 ? rg.rank : null, rg.items.length, idx)).join('')).join('')}
                    </div>
                </div>`;

            el.querySelectorAll('.fu-row-check:not(.readonly)').forEach(btn => {
                btn.addEventListener('click', () => toggleUpgradeLevel(btn.dataset.slug, Number(btn.dataset.level)));
            });
        }

        function renderUpgradeRow(item, def, showRank, groupSize, groupIdx) {
            const u = item.upgrade;
            const lv = item.level;
            const unlocked = isLevelUnlocked(u.slug, lv.level);
            const canToggle = _isOwner;
            const isMulti = u.maxLevel > 1;
            const displayName = isMulti ? `${u.name} Lv ${lv.level}` : u.name;

            const salvageHtml = lv.salvage.length ? `<span class="fu-row-salvage">${lv.salvage.map(s => {
                const mat = def.materials.find(m => m.slug === s.slug);
                return `<span class="fu-salvage" title="${mat?.name || s.slug}"><img src="${mat?.icon || ''}" alt="" width="16" height="16">${s.amount}</span>`;
            }).join('')}</span>` : '';

            const checkSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="12" height="12"><path d="M20 6L9 17l-5-5"/></svg>';

            return `<div class="fu-row${unlocked ? ' unlocked' : ''}${showRank !== null ? ' fu-row-rank-start' : ''}" style="--fc:${def.color}">
                <button class="fu-row-check${canToggle ? '' : ' readonly'}" data-slug="${u.slug}" data-level="${lv.level}" ${canToggle ? '' : 'disabled'}>
                    <span class="fu-check-box">${unlocked ? checkSvg : ''}</span>
                </button>
                <span class="fu-row-rank${showRank === null ? ' fu-row-rank-hidden' : ''}${typeof lv.rank === 'string' ? ' fu-row-rank-vip' : ''}">${lv.rank}</span>
                <span class="fu-row-name">
                    <span class="fu-row-name-text">${esc(displayName)}</span>
                    <span class="fu-row-desc">${esc(u.description)}</span>
                </span>
                <span class="fu-row-cat">${CAT_LABELS[u.category] || u.category}</span>
                <span class="fu-row-effect">${lv.effect ? esc(lv.effect) : ''}</span>
                <span class="fu-row-cost">
                    <span class="fu-cost-credits"><img src="/assets/icons/credits.webp" alt="Credits" width="14" height="14">${lv.credits.toLocaleString()}</span>
                    ${salvageHtml}
                </span>
            </div>`;
        }

        function renderCapstones(def) {
            const el = document.getElementById('fuCapstones');
            if (!def.capstones?.length) { el.innerHTML = ''; return; }
            const checkSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" width="14" height="14"><path d="M20 6L9 17l-5-5"/></svg>';
            el.innerHTML = `
                <div class="fu-capstones-section" style="--fc:${def.color}">
                    <div class="fu-capstones-header">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        Capstones
                    </div>
                    <div class="fu-capstones-grid">
                        ${def.capstones.map(c => {
                            const unlocked = isCapstoneUnlocked(c.rank);
                            const canToggle = _isOwner;
                            return `
                            <div class="fu-capstone${unlocked ? ' unlocked' : ''}">
                                <div class="fu-capstone-left">
                                    <button class="fu-capstone-check${canToggle ? '' : ' readonly'}" data-rank="${c.rank}" ${canToggle ? '' : 'disabled'}>
                                        <span class="fu-capstone-num">${c.rank}</span>
                                        ${unlocked ? `<span class="fu-capstone-tick">${checkSvg}</span>` : ''}
                                    </button>
                                </div>
                                <div class="fu-capstone-body">
                                    <div class="fu-capstone-name">${esc(c.name)}</div>
                                    <div class="fu-capstone-meta">
                                        <span class="fu-capstone-req">${c.nodesRequired} upgrades required</span>
                                        ${c.reward ? `<span class="fu-capstone-reward">${esc(c.reward)}</span>` : ''}
                                    </div>
                                </div>
                            </div>`;
                        }).join('')}
                    </div>
                </div>`;
            el.querySelectorAll('.fu-capstone-check:not(.readonly)').forEach(btn => {
                btn.addEventListener('click', () => toggleCapstone(Number(btn.dataset.rank)));
            });
        }

        async function toggleUpgradeLevel(slug, level) {
            if (!_isOwner) return;
            try {
                const res = await fetch(`${ACCOUNTS_API}/upgrades/${_fuFaction}/toggle`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ upgrade_slug: slug, level }),
                });
                if (!res.ok) return;
                const j = await res.json();
                if (!j.success) return;
                if (j.data.action === 'added') {
                    _fuUserData.upgrades.push({ upgrade_slug: slug, level });
                } else {
                    _fuUserData.upgrades = _fuUserData.upgrades.filter(u => !(u.upgrade_slug === slug && u.level === level));
                }
                const def = window.FACTION_UPGRADES?.[_fuFaction];
                if (def) renderAll(def);
            } catch (e) { console.error('Toggle upgrade failed:', e); }
        }

        async function toggleCapstone(rank) {
            if (!_isOwner) return;
            try {
                const res = await fetch(`${ACCOUNTS_API}/upgrades/${_fuFaction}/capstone/toggle`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ capstone_rank: rank }),
                });
                if (!res.ok) return;
                const j = await res.json();
                if (!j.success) return;
                if (j.data.action === 'added') {
                    _fuUserData.capstones.push(rank);
                } else {
                    _fuUserData.capstones = _fuUserData.capstones.filter(r => r !== rank);
                }
                const def = window.FACTION_UPGRADES?.[_fuFaction];
                if (def) renderAll(def);
            } catch (e) { console.error('Toggle capstone failed:', e); }
        }

        /* ═══════════════════════════════════════════════════════════
           TAB SYSTEM
        ═══════════════════════════════════════════════════════════ */
        function setupTabs() {
            const tabs = document.querySelectorAll('.pf-tab[data-tab]');
            const panels = document.querySelectorAll('.pf-tab-panel');
            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    if (tab.classList.contains('pf-tab--disabled')) return;
                    tabs.forEach(t => t.classList.remove('active'));
                    panels.forEach(p => p.classList.remove('active'));
                    tab.classList.add('active');
                    document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
                });
            });
        }

        /* ═══════════════════════════════════════════════════════════
           SHARE BUTTON
        ═══════════════════════════════════════════════════════════ */
        function setupShareBtn(p) {
            document.getElementById('pfShareBtn').addEventListener('click', function() {
                let url;
                if (p.username) url = window.location.origin + '/player-profiles/u/' + encodeURIComponent(p.username);
                else if (p.bungieName) url = window.location.origin + '/player-profiles/bungie/' + encodeURIComponent(p.bungieName);
                else url = window.location.href;
                navigator.clipboard.writeText(url).then(() => {
                    this.title = 'Copied!';
                    setTimeout(() => this.title = 'Copy profile link', 2000);
                });
            });
        }

        /* ═══════════════════════════════════════════════════════════
           HELPERS
        ═══════════════════════════════════════════════════════════ */
        function showError(title, text) {
            loadingEl.style.display = 'none';
            errorTitle.textContent = title;
            errorText.textContent = text;
            errorEl.style.display = '';
        }
        function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

    })();
    </script>
</body>
</html>
