/* ═══════════════════════════════════════════════════════════
   PROFILE – Tracker-inspired Glassmorphism
   MarathonDB · 2026
   Rounded · Frosted · High-contrast
═══════════════════════════════════════════════════════════ */

/* ── Design Tokens ── */
:root {
    --pf-glass: rgba(255,255,255,0.035);
    --pf-glass-hover: rgba(255,255,255,0.06);
    --pf-glass-border: rgba(255,255,255,0.10);
    --pf-glass-border-light: rgba(255,255,255,0.16);
    --pf-surface: #111114;
    --pf-surface-raised: rgba(255,255,255,0.045);
    --pf-text: rgba(255,255,255,0.92);
    --pf-text-secondary: rgba(255,255,255,0.58);
    --pf-text-muted: rgba(255,255,255,0.38);
    --pf-amber: #fbbf24;
    --pf-green: #4ade80;
    --pf-red: #f87171;
    --pf-purple: #a78bfa;
    --pf-blue: #60a5fa;
    --pf-radius: 10px;
    --pf-radius-sm: 6px;
    --pf-radius-xs: 4px;
}

/* ═══════════════════════════════════════════════════════════
   PAGE SHELL
═══════════════════════════════════════════════════════════ */
.pf-page {
    padding-top: var(--nav-height);
    min-height: 100vh;
}

/* ═══════════════════════════════════════════════════════════
   LOADING / ERROR
═══════════════════════════════════════════════════════════ */
.pf-loading {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 12px; padding: 140px 24px;
    color: var(--pf-text-secondary); font-size: 0.85rem;
}
.pf-error-wrap {
    display: flex; align-items: center; justify-content: center;
    padding: 120px 24px; text-align: center;
}
.pf-error-title {
    font-size: 1.2rem; font-weight: 700;
    color: var(--pf-text); margin-bottom: 8px;
}
.pf-error-text {
    font-size: 0.82rem; color: var(--pf-text-secondary);
    margin-bottom: 24px;
}
.pf-back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--neon); text-decoration: none;
    font-size: 0.78rem; font-weight: 600;
}
.pf-back-link:hover { text-decoration: underline; }

/* ═══════════════════════════════════════════════════════════
   DEV NOTICE
═══════════════════════════════════════════════════════════ */
.pf-api-notice {
    display: flex; align-items: center; gap: 10px;
    max-width: 1200px; margin: 0 auto;
    padding: 10px 32px;
    font-size: 0.72rem; color: rgba(212,255,0,0.5);
}
.pf-api-notice svg { flex-shrink: 0; opacity: 0.45; }

/* ═══════════════════════════════════════════════════════════
   BANNER
═══════════════════════════════════════════════════════════ */
.pf-banner {
    position: relative;
    width: 100%; height: 180px;
    background: linear-gradient(135deg, #08090b 0%, #0c1008 30%, #0e0e10 60%, #0a0c14 100%);
    overflow: hidden;
}
.pf-banner::before {
    content: ''; position: absolute; inset: 0;
    background:
        radial-gradient(ellipse 500px 180px at 15% 90%, rgba(212,255,0,0.05), transparent),
        radial-gradient(ellipse 300px 250px at 85% 20%, rgba(96,165,250,0.03), transparent);
    pointer-events: none;
}
.pf-banner-fade {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, var(--bg-body, #0a0a0c) 100%);
    pointer-events: none;
}
.pf-banner-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    max-width: 1200px; margin: 0 auto;
    padding: 0 32px 20px;
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 20px; z-index: 2;
}

/* ── Identity ── */
.pf-identity { display: flex; align-items: flex-end; gap: 16px; }
.pf-avatar-wrap {
    width: 72px; height: 72px;
    border: 2px solid var(--neon);
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    flex-shrink: 0; position: relative;
    box-shadow: 0 0 20px rgba(212,255,0,0.1);
    overflow: hidden;
}
.pf-avatar { width: 100%; height: 100%; object-fit: cover; display: block; }
.pf-avatar-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.12);
}
.pf-name-area { padding-bottom: 2px; }
.pf-username {
    font-size: 1.5rem; font-weight: 800;
    color: #fff; letter-spacing: 0.02em; line-height: 1.1;
}
.pf-subtitle {
    font-size: 0.7rem; color: var(--pf-text-secondary);
    margin-top: 3px;
}
.pf-badges { display: flex; gap: 6px; margin-top: 6px; }
.pf-badge {
    font-size: 0.54rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; padding: 2px 8px;
    border: 1px solid transparent;
    border-radius: var(--pf-radius-xs);
}
.pf-badge--premium {
    background: rgba(212,255,0,0.08); color: var(--neon);
    border-color: rgba(212,255,0,0.15);
}
.pf-badge--early {
    background: rgba(167,139,250,0.08); color: var(--pf-purple);
    border-color: rgba(167,139,250,0.15);
}

/* ── Header right ── */
.pf-header-right { display: flex; align-items: flex-end; gap: 10px; }
.pf-share-btn {
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius-sm);
    color: var(--pf-text-secondary); cursor: pointer; transition: all 0.2s;
}
.pf-share-btn:hover {
    background: rgba(212,255,0,0.06); border-color: rgba(212,255,0,0.25);
    color: var(--neon);
}

/* ═══════════════════════════════════════════════════════════
   TABS
═══════════════════════════════════════════════════════════ */
.pf-tabs-wrap {
    background: rgba(10,10,12,0.92);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--pf-glass-border);
    position: sticky; top: var(--nav-height); z-index: 40;
}
.pf-tabs {
    max-width: 1200px; margin: 0 auto;
    display: flex; padding: 0 32px;
}
.pf-tab {
    padding: 13px 20px;
    font-size: 0.7rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--pf-text-muted);
    background: none; border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer; transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
}
.pf-tab:hover { color: var(--pf-text-secondary); }
.pf-tab.active { color: var(--neon); border-bottom-color: var(--neon); }
.pf-tab--disabled { pointer-events: none; opacity: 0.2; }
.pf-tab-soon {
    font-size: 0.48rem; background: rgba(255,255,255,0.05);
    padding: 1px 5px; margin-left: 6px; vertical-align: middle;
    text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--pf-text-muted);
    border-radius: var(--pf-radius-xs);
}

/* ── Tab Panels ── */
.pf-tab-panel { display: none; }
.pf-tab-panel.active {
    display: block;
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 32px 80px;
}

/* ═══════════════════════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════════════════════ */
.pf-btn {
    padding: 8px 16px; font-size: 0.68rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    border: 1px solid var(--pf-glass-border-light);
    border-radius: var(--pf-radius-sm);
    background: var(--pf-glass); color: var(--pf-text-secondary);
    cursor: pointer; transition: all 0.2s;
}
.pf-btn:hover {
    background: var(--pf-glass-hover); color: var(--pf-text);
    border-color: rgba(255,255,255,0.2);
}
.pf-btn--primary {
    background: var(--neon); border-color: var(--neon);
    color: #000; font-weight: 700;
}
.pf-btn--primary:hover { background: var(--neon-dim); border-color: var(--neon-dim); }
.pf-btn--sm  { padding: 6px 12px; font-size: 0.64rem; }
.pf-btn--xs  { padding: 4px 10px; font-size: 0.6rem; }
.pf-btn--ghost { background: none; border-color: transparent; }
.pf-btn--ghost:hover { background: rgba(255,255,255,0.03); }
.pf-btn--danger { border-color: rgba(248,113,113,0.3); color: var(--pf-red); }
.pf-btn--danger:hover { background: rgba(248,113,113,0.08); border-color: var(--pf-red); }

/* ═══════════════════════════════════════════════════════════
   FACTION UPGRADES
═══════════════════════════════════════════════════════════ */

/* ── Faction Selector Bar ── */
.fu-faction-bar {
    display: flex; gap: 6px;
    margin-bottom: 20px;
}
.fu-faction-btn {
    flex: 1 1 0;
    display: flex; align-items: center; justify-content: center; gap: 5px;
    padding: 6px 4px;
    background: var(--fc);
    border: none;
    border-radius: var(--pf-radius-sm);
    color: #fff; font-size: 0.58rem;
    font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px;
    cursor: pointer; transition: all 0.2s;
    overflow: hidden;
}
.fu-faction-btn-icon {
    width: 16px; height: 16px; object-fit: cover;
    filter: brightness(0) invert(1);
    transition: filter 0.2s;
}
.fu-faction-btn:hover:not(.disabled) {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--fc) 45%, transparent);
}
.fu-faction-btn:hover:not(.disabled) .fu-faction-btn-icon {
    filter: brightness(0) invert(1) drop-shadow(0 0 4px rgba(255,255,255,0.4));
}
.fu-faction-btn.active {
    box-shadow: 0 0 0 2px #fff, 0 4px 20px color-mix(in srgb, var(--fc) 45%, transparent);
}
.fu-faction-btn.disabled {
    opacity: 0.15; cursor: not-allowed; pointer-events: none;
}

/* ── Progress Card ── */
.fu-progress { margin-bottom: 20px; }
.fu-progress-card {
    background: var(--pf-glass);
    border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius);
    padding: 18px 24px 14px;
    position: relative; overflow: hidden;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}
.fu-progress-card::before {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--fc), transparent 70%);
    opacity: 0.6;
}
.fu-progress-top {
    display: flex; align-items: baseline; justify-content: space-between;
    flex-wrap: wrap; gap: 8px; margin-bottom: 12px;
}
.fu-progress-title {
    font-size: 0.95rem; font-weight: 700;
    color: #fff;
}
.fu-progress-stats {
    display: flex; align-items: baseline; gap: 14px;
}
.fu-progress-stat {
    font-size: 0.6rem; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--pf-text-muted);
}
.fu-progress-stat-val {
    font-weight: 700; color: var(--pf-text-secondary);
}
.fu-progress-pct {
    font-size: 0.82rem; font-weight: 700;
    color: var(--fc);
}
.fu-progress-bar {
    height: 4px; background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
}
.fu-progress-fill {
    height: 100%; background: var(--fc);
    border-radius: 2px;
    transition: width 0.4s ease;
    box-shadow: 0 0 6px color-mix(in srgb, var(--fc) 25%, transparent);
}

/* ── Upgrade Table ── */
.fu-table {
    background: var(--pf-glass);
    border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius);
    overflow: hidden;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}

/*  5 visible columns: check · rank · name · effect · cost
    Category column is hidden to reclaim horizontal space. */
.fu-table-head {
    display: grid;
    grid-template-columns: 36px 60px 1fr 1fr auto;
    gap: 0; padding: 0 20px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--pf-glass-border);
}
.fu-th {
    font-size: 0.55rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--pf-text-muted);
    padding: 10px 0;
}
.fu-th-rank { white-space: normal; line-height: 1.4; }
.fu-th-cat  { display: none; }
.fu-th-cost { text-align: right; padding-right: 4px; }

/* ── Rows ── */
.fu-table-body { position: relative; }
.fu-row {
    display: grid;
    grid-template-columns: 36px 60px 1fr 1fr auto;
    gap: 0; padding: 0 20px;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.15s;
    min-height: 50px;
}
.fu-row:nth-child(even) { background: rgba(255,255,255,0.018); }
.fu-row:last-child { border-bottom: none; }
.fu-row:hover { background: rgba(255,255,255,0.04); }
.fu-row.unlocked { background: color-mix(in srgb, var(--fc) 4%, transparent); }
.fu-row.unlocked:nth-child(even) { background: color-mix(in srgb, var(--fc) 6%, transparent); }
.fu-row.unlocked:hover { background: color-mix(in srgb, var(--fc) 8%, transparent); }
.fu-row-rank-start { border-top: 1px solid rgba(255,255,255,0.08); }
.fu-row-rank-start:first-child { border-top: none; }

/* Checkbox */
.fu-row-check {
    width: 20px; height: 20px;
    border: none; background: none; padding: 0;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
}
.fu-row-check.readonly { cursor: default; }
.fu-check-box {
    width: 18px; height: 18px;
    border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: var(--pf-radius-xs); background: transparent;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s; color: transparent;
}
.fu-row-check:hover:not(.readonly):not(:disabled) .fu-check-box {
    border-color: rgba(255,255,255,0.35);
}
.fu-row.unlocked .fu-check-box {
    border-color: var(--fc);
    background: color-mix(in srgb, var(--fc) 15%, transparent);
    color: var(--fc);
}
.fu-row-check.readonly .fu-check-box { opacity: 0.5; }

/* Rank */
.fu-row-rank {
    font-size: 0.85rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    text-align: center;
    display: flex; align-items: center; justify-content: center;
    align-self: stretch;
}
.fu-row-rank-hidden { visibility: hidden; }
.fu-row-rank-vip {
    font-size: 0.55rem; letter-spacing: 0.06em;
    color: var(--pf-amber); opacity: 0.8;
}

/* Name + Description */
.fu-row-name {
    display: flex; flex-direction: column; gap: 1px;
    padding: 10px 14px 10px 0; min-width: 0;
}
.fu-row-name-text {
    font-size: 0.78rem; font-weight: 600;
    color: rgba(255,255,255,0.82);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.fu-row.unlocked .fu-row-name-text { color: #fff; }
.fu-row-desc {
    font-size: 0.6rem; color: var(--pf-text-muted);
    line-height: 1.3;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* Category – hidden to save horizontal space */
.fu-row-cat { display: none; }

/* Effect */
.fu-row-effect {
    font-size: 0.68rem; color: var(--pf-text-secondary);
    padding: 0 10px; min-width: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.fu-row.unlocked .fu-row-effect { color: rgba(255,255,255,0.7); }

/* Cost */
.fu-row-cost {
    display: flex; flex-direction: column; align-items: flex-end;
    gap: 3px; padding: 10px 0;
}
.fu-cost-credits {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 0.72rem; font-weight: 600;
    color: var(--pf-amber);
    font-variant-numeric: tabular-nums; white-space: nowrap;
}
.fu-cost-credits img { width: 14px; height: 14px; flex-shrink: 0; }
.fu-row-salvage { display: flex; align-items: center; gap: 6px; }
.fu-salvage {
    display: inline-flex; align-items: center; gap: 3px;
    font-size: 0.6rem; color: var(--pf-text-muted);
    font-variant-numeric: tabular-nums;
}
.fu-salvage img { width: 16px; height: 16px; object-fit: contain; }

/* ── Capstones ── */
.fu-capstones { margin-top: 20px; }
.fu-capstones-section {
    background: var(--pf-glass);
    border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius);
    overflow: hidden;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}
.fu-capstones-header {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 20px;
    font-size: 0.65rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--pf-text-secondary);
    background: rgba(255,255,255,0.015);
    border-bottom: 1px solid var(--pf-glass-border);
}
.fu-capstones-header svg { opacity: 0.3; }
.fu-capstones-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0;
}
.fu-capstone {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    border-right: 1px solid rgba(255,255,255,0.06);
    transition: background 0.15s;
}
.fu-capstone:hover { background: rgba(255,255,255,0.03); }
.fu-capstone.unlocked { background: color-mix(in srgb, var(--fc) 3%, transparent); }

.fu-capstone-left { flex-shrink: 0; }
.fu-capstone-check {
    width: 32px; height: 32px;
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 50%; background: transparent;
    display: flex; align-items: center; justify-content: center;
    position: relative;
    cursor: pointer; transition: all 0.2s; padding: 0;
    color: var(--pf-text-muted);
}
.fu-capstone-check:hover:not(.readonly):not(:disabled) {
    border-color: rgba(255,255,255,0.25);
}
.fu-capstone.unlocked .fu-capstone-check {
    border-color: var(--fc);
    background: color-mix(in srgb, var(--fc) 10%, transparent);
    color: var(--fc);
    box-shadow: 0 0 8px color-mix(in srgb, var(--fc) 12%, transparent);
}
.fu-capstone-check.readonly { cursor: default; opacity: 0.5; }
.fu-capstone-num { font-size: 0.7rem; font-weight: 700; line-height: 1; }
.fu-capstone-tick {
    position: absolute; bottom: -2px; right: -2px;
    width: 14px; height: 14px;
    background: var(--fc); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #000;
}
.fu-capstone-tick svg { width: 8px; height: 8px; stroke-width: 4; }

.fu-capstone-body {
    display: flex; flex-direction: column; gap: 2px; min-width: 0;
}
.fu-capstone-name {
    font-size: 0.75rem; font-weight: 600;
    color: rgba(255,255,255,0.80);
}
.fu-capstone.unlocked .fu-capstone-name { color: #fff; }
.fu-capstone-meta {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
}
.fu-capstone-req {
    font-size: 0.56rem; color: var(--pf-text-muted);
    text-transform: uppercase; letter-spacing: 0.04em;
}
.fu-capstone-reward {
    font-size: 0.6rem; color: var(--pf-amber); opacity: 0.65;
}

/* ═══════════════════════════════════════════════════════════
   ITEM PICKER MODAL
═══════════════════════════════════════════════════════════ */
.pf-picker-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    z-index: 1000; display: none;
    align-items: center; justify-content: center;
}
.pf-picker-overlay.active { display: flex; }
.pf-picker {
    background: var(--pf-surface);
    border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius);
    width: 90%; max-width: 560px; max-height: 80vh;
    display: flex; flex-direction: column;
}
.pf-picker-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px; border-bottom: 1px solid var(--pf-glass-border);
}
.pf-picker-title {
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--pf-text-secondary);
}
.pf-picker-close {
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    background: none; border: none; cursor: pointer;
    color: var(--pf-text-secondary); transition: color 0.15s;
}
.pf-picker-close:hover { color: #fff; }
.pf-picker-search {
    padding: 10px 20px; border-bottom: 1px solid var(--pf-glass-border);
}
.pf-picker-search input {
    width: 100%; background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--pf-radius-sm);
    padding: 8px 12px; font-size: 0.78rem; color: #fff; font-family: inherit;
}
.pf-picker-search input:focus { outline: none; border-color: rgba(212,255,0,0.3); }
.pf-picker-search input::placeholder { color: var(--pf-text-muted); }
.pf-picker-items { flex: 1; overflow-y: auto; padding: 8px 0; }
.pf-picker-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 20px; cursor: pointer; transition: background 0.12s;
}
.pf-picker-item:hover { background: rgba(255,255,255,0.03); }
.pf-picker-item-icon {
    width: 40px; height: 40px; object-fit: contain; flex-shrink: 0;
    background: rgba(255,255,255,0.03); border-radius: var(--pf-radius-xs); padding: 4px;
}
.pf-picker-item-name { font-size: 0.8rem; color: #fff; }
.pf-picker-item-meta { font-size: 0.65rem; color: var(--pf-text-muted); }
.pf-picker-empty {
    padding: 30px 20px; text-align: center;
    font-size: 0.72rem; color: var(--pf-text-muted);
}

/* ═══════════════════════════════════════════════════════════
   LOADOUT BUILDER TAB
═══════════════════════════════════════════════════════════ */

/* ── Runner selector bar ── */
.lb-runner-bar {
    background: var(--pf-glass);
    border-bottom: 1px solid var(--pf-glass-border);
    padding: 12px 0;
    overflow-x: auto;
}
.lb-runner-bar-inner {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; padding: 0 24px;
    min-width: max-content;
}
.lb-runner-bar-loading {
    font-size: 0.72rem; color: var(--pf-text-muted);
    padding: 20px 0;
}
.lb-runner-btn {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius-sm);
    padding: 8px 12px; cursor: pointer; transition: all 0.2s;
    min-width: 72px;
}
.lb-runner-btn:hover {
    border-color: var(--pf-glass-border-light);
    background: var(--pf-glass-hover);
}
.lb-runner-btn.active {
    border-color: var(--neon); background: rgba(212,255,0,0.04);
    box-shadow: 0 0 16px rgba(212,255,0,0.08);
}
.lb-runner-btn-img {
    width: 40px; height: 60px; object-fit: cover;
    filter: grayscale(0.5) brightness(0.7);
    transition: filter 0.2s;
}
.lb-runner-btn:hover .lb-runner-btn-img,
.lb-runner-btn.active .lb-runner-btn-img {
    filter: grayscale(0) brightness(1);
}
.lb-runner-btn-name {
    font-size: 0.55rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--pf-text-secondary); transition: color 0.2s;
}
.lb-runner-btn.active .lb-runner-btn-name { color: var(--neon); }

/* ── Empty state ── */
.lb-empty {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 100px 24px; text-align: center; gap: 12px;
}
.lb-empty-title {
    font-size: 1rem; font-weight: 700; color: var(--pf-text-muted);
    text-transform: uppercase; letter-spacing: 0.08em;
}
.lb-empty-text { font-size: 0.75rem; color: rgba(255,255,255,0.1); }

/* ── Main layout ── */
.lb-main {
    max-width: 1320px; margin: 0 auto;
    padding: 20px 24px 60px;
}
.lb-columns {
    display: grid;
    grid-template-columns: 280px 1fr 300px;
    gap: 20px; align-items: start;
}

/* ── Left: Runner info + stats ── */
.lb-col-left { position: sticky; top: calc(var(--nav-height) + 50px); }
.lb-runner-header { margin-bottom: 16px; }
.lb-runner-name {
    font-size: 1.4rem; font-weight: 700;
    color: #fff; letter-spacing: 0.04em; line-height: 1.1;
}
.lb-runner-role {
    font-size: 0.68rem; color: var(--pf-text-muted);
    text-transform: uppercase; letter-spacing: 0.04em; margin-top: 4px;
}
.lb-runner-desc {
    font-size: 0.72rem; color: var(--pf-text-muted);
    margin-top: 8px; line-height: 1.5;
}

/* Abilities */
.lb-abilities { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
.lb-ability {
    display: flex; align-items: center; gap: 5px;
    padding: 4px 10px;
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius-xs);
    font-size: 0.62rem; color: var(--pf-text-secondary);
}
.lb-ability-type {
    font-weight: 700; letter-spacing: 0.06em;
    color: var(--neon); font-size: 0.5rem;
}

/* Runner stats */
.lb-stats {
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius);
    padding: 12px 0;
}
.lb-stat-row {
    display: grid; grid-template-columns: 110px 1fr 44px auto;
    align-items: center; gap: 8px; padding: 5px 14px;
    transition: background 0.12s;
}
.lb-stat-row:hover { background: rgba(255,255,255,0.02); }
.lb-stat-label {
    font-size: 0.62rem; color: var(--pf-text-secondary);
    text-transform: uppercase; letter-spacing: 0.03em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.lb-stat-bar-wrap { height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; }
.lb-stat-bar { height: 100%; background: var(--neon); border-radius: 2px; transition: width 0.4s ease; }
.lb-stat-value {
    font-size: 0.68rem; font-weight: 600; color: #fff;
    font-variant-numeric: tabular-nums; text-align: right; min-width: 44px;
}
.lb-stat-delta {
    font-size: 0.58rem; font-weight: 700;
    font-variant-numeric: tabular-nums; min-width: 30px;
}
.lb-delta--good { color: var(--pf-green); }
.lb-delta--bad  { color: var(--pf-red); }

/* ── Center: Hero + equipment ── */
.lb-col-center {
    display: flex; align-items: center; justify-content: center;
    min-height: 520px;
}
.lb-hero-area {
    position: relative; display: grid;
    grid-template-areas:
        "left-equip hero   right-shield"
        "left-equip hero   right-shield"
        "cores      hero   implants"
        "cores      hero   implants";
    grid-template-columns: 80px 1fr 80px;
    grid-template-rows: auto 1fr auto auto;
    gap: 8px; width: 100%; max-width: 480px; align-items: center;
}
.lb-equip-left       { grid-area: left-equip;   display: flex; flex-direction: column; gap: 8px; align-items: center; }
.lb-equip-right-top  { grid-area: right-shield; display: flex; flex-direction: column; gap: 8px; align-items: center; align-self: start; padding-top: 20px; }
.lb-equip-cores      { grid-area: cores;        display: flex; flex-direction: column; gap: 6px; align-items: center; }
.lb-equip-implants   { grid-area: implants;     display: flex; flex-direction: column; gap: 6px; align-items: center; }
.lb-equip-section-label {
    font-size: 0.45rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--pf-text-muted);
}
.lb-implant-row { display: flex; gap: 4px; }

.lb-hero-img-wrap {
    grid-area: hero;
    display: flex; align-items: center; justify-content: center;
    min-height: 400px;
}
.lb-hero-img {
    max-width: 100%; max-height: 480px; object-fit: contain;
    filter: drop-shadow(0 0 40px rgba(212,255,0,0.06));
}

/* Slot base */
.lb-slot {
    width: 64px; height: 64px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 3px;
    background: var(--pf-glass); border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--pf-radius-sm);
    cursor: pointer; transition: all 0.2s; position: relative;
}
.lb-slot:hover { border-color: rgba(212,255,0,0.25); background: rgba(212,255,0,0.03); }
.lb-slot:hover .lb-slot-label { color: rgba(212,255,0,0.6); }
.lb-slot--sm { width: 48px; height: 48px; }
.lb-slot--disabled { opacity: 0.2; pointer-events: none; }
.lb-slot--filled { border-color: rgba(255,255,255,0.15); }
.lb-slot-label {
    font-size: 0.4rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--pf-text-muted); transition: color 0.2s;
}
.lb-slot-icon { display: flex; align-items: center; justify-content: center; }
.lb-slot-icon img { width: 36px; height: 36px; object-fit: contain; }
.lb-slot--sm .lb-slot-icon img { width: 28px; height: 28px; }

/* ── Right: Weapon + stats ── */
.lb-col-right { position: sticky; top: calc(var(--nav-height) + 50px); }

.lb-section-label {
    font-size: 0.55rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--pf-text-muted);
    margin-bottom: 8px; display: block;
}
.lb-weapon-section {
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius);
    padding: 14px;
}
.lb-weapon-top { display: flex; gap: 10px; align-items: stretch; }
.lb-weapon-mods-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 4px; flex-shrink: 0;
}
.lb-weapon-slot {
    flex: 1; min-height: 100px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius-sm);
    cursor: pointer; transition: all 0.2s; padding: 10px;
}
.lb-weapon-slot:hover { border-color: rgba(212,255,0,0.25); background: rgba(212,255,0,0.03); }
.lb-weapon-slot-label {
    font-size: 0.68rem; font-weight: 600;
    color: var(--pf-text-muted); transition: color 0.2s;
}
.lb-weapon-slot:hover .lb-weapon-slot-label { color: rgba(212,255,0,0.5); }
.lb-weapon-img { max-width: 100%; max-height: 100px; object-fit: contain; }

/* Weapon stats */
.lb-weapon-stats {
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-top: none; border-radius: 0 0 var(--pf-radius) var(--pf-radius);
    max-height: 500px; overflow-y: auto;
}
.lb-ws-empty {
    padding: 30px 14px; text-align: center;
    color: var(--pf-text-muted); font-size: 0.72rem;
}
.lb-ws-section + .lb-ws-section { border-top: 1px solid rgba(255,255,255,0.04); }
.lb-ws-section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 14px; background: rgba(255,255,255,0.02);
    font-size: 0.58rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--pf-text-muted);
}
.lb-ws-section-score {
    font-size: 0.72rem; font-weight: 700; color: #fff;
    font-variant-numeric: tabular-nums;
}
.lb-ws-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 5px 14px; font-size: 0.68rem; transition: background 0.12s;
}
.lb-ws-row:hover { background: rgba(255,255,255,0.02); }
.lb-ws-label { color: var(--pf-text-secondary); }
.lb-ws-value { font-weight: 600; color: #fff; font-variant-numeric: tabular-nums; }
.lb-ws-ttk--green .lb-ws-value  { color: var(--pf-green); }
.lb-ws-ttk--blue  .lb-ws-value  { color: var(--pf-blue); }
.lb-ws-ttk--purple .lb-ws-value { color: var(--pf-purple); }

/* ── Footer actions ── */
.lb-footer-actions {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 0 10px; gap: 12px;
    border-top: 1px solid var(--pf-glass-border); margin-top: 24px;
}
.lb-footer-left { display: flex; gap: 8px; }
.lb-footer-right { display: flex; gap: 8px; align-items: center; }
.lb-name-input {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--pf-radius-sm);
    padding: 6px 12px; font-size: 0.72rem; color: #fff;
    font-family: inherit; width: 200px;
}
.lb-name-input:focus { outline: none; border-color: var(--neon); }
.lb-name-input::placeholder { color: var(--pf-text-muted); }

/* ── Saved loadouts ── */
.lb-saved { margin-top: 20px; }
.lb-saved-header { margin-bottom: 10px; }
.lb-saved-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px;
}
.lb-saved-empty { font-size: 0.72rem; color: var(--pf-text-muted); padding: 16px 0; }
.lb-saved-card {
    background: var(--pf-glass); border: 1px solid var(--pf-glass-border);
    border-radius: var(--pf-radius-sm);
    padding: 12px 14px; cursor: pointer;
    transition: border-color 0.2s, background 0.2s; position: relative;
}
.lb-saved-card:hover { border-color: rgba(212,255,0,0.2); background: var(--pf-glass-hover); }
.lb-saved-card-name { font-size: 0.78rem; font-weight: 700; color: #fff; margin-bottom: 3px; }
.lb-saved-card-detail { font-size: 0.65rem; color: var(--pf-text-muted); }
.lb-saved-card-delete {
    position: absolute; top: 6px; right: 8px;
    background: none; border: none; cursor: pointer;
    font-size: 1rem; color: var(--pf-text-muted); transition: color 0.15s; line-height: 1;
}
.lb-saved-card-delete:hover { color: var(--pf-red); }

/* ═══════════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
    /* Loadout builder */
    .lb-columns { grid-template-columns: 240px 1fr 260px; gap: 14px; }
    .lb-col-left, .lb-col-right { position: static; }
    /* Faction upgrades */
    .fu-table-head, .fu-row {
        grid-template-columns: 36px 50px 1fr 1fr auto;
    }
    .fu-capstones-grid {
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    }
}

@media (max-width: 900px) {
    .fu-faction-bar { flex-wrap: wrap; }
    .fu-faction-btn { flex: 1 1 calc(33.33% - 6px); min-width: 0; }
}

@media (max-width: 768px) {
    .pf-banner { height: 160px; }
    .pf-banner-content { padding-left: 16px; padding-right: 16px; }
    .pf-tabs { padding: 0 16px; }
    .pf-tab-panel.active { padding: 20px 16px 60px; }
    .pf-api-notice { padding: 10px 16px; }
    /* Loadout builder – stack to 1 column */
    .lb-columns { grid-template-columns: 1fr; }
    .lb-col-center { order: -1; min-height: 340px; }
    .lb-hero-area { max-width: 360px; margin: 0 auto; }
    .lb-hero-img-wrap { min-height: 280px; }
    .lb-hero-img { max-height: 320px; }
    .lb-main { padding: 16px 16px 40px; }
    .lb-footer-actions { flex-direction: column; align-items: stretch; }
    .lb-footer-right { flex-direction: column; }
    .lb-name-input { width: 100%; }
    /* Faction upgrades – collapse to compact rows */
    .fu-table-head { display: none; }
    .fu-row {
        grid-template-columns: 32px 1fr auto;
        grid-template-rows: auto auto;
        padding: 10px 16px; gap: 0 10px;
    }
    .fu-row-rank   { display: none; }
    .fu-row-effect { display: none; }
    .fu-row-check  { grid-row: 1 / 3; align-self: center; }
    .fu-row-name   { grid-column: 2; padding: 0; }
    .fu-row-cost   { grid-column: 3; grid-row: 1 / 3; align-items: flex-end; }
    .fu-row-desc   { font-size: 0.58rem; }
    .fu-capstones-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 640px) {
    .pf-banner { height: 140px; }
    .pf-banner-content {
        flex-direction: column; align-items: flex-start;
        gap: 8px; padding-bottom: 12px;
    }
    .pf-header-right { align-self: flex-start; }
    .pf-avatar-wrap { width: 52px; height: 52px; }
    .pf-username { font-size: 1.15rem; }
    .pf-tab { padding: 11px 14px; font-size: 0.64rem; }
    /* Faction upgrades */
    .fu-faction-bar { gap: 6px; }
    .fu-faction-btn {
        flex: 1 1 calc(50% - 3px); padding: 6px 4px;
        font-size: 0.56rem; letter-spacing: 0.5px;
    }
    .fu-faction-btn-icon { width: 14px; height: 14px; }
    .fu-progress-card { padding: 14px 16px 12px; }
    .fu-progress-top { flex-direction: column; gap: 4px; }
    .fu-progress-stats { gap: 10px; }
    .fu-row { padding: 8px 12px; }
    .fu-capstones-grid { grid-template-columns: 1fr; }
    .fu-capstone { padding: 10px 14px; gap: 10px; }
    /* Loadout builder */
    .lb-runner-btn { min-width: 56px; padding: 6px 8px; }
    .lb-runner-btn-img { width: 30px; height: 46px; }
    .lb-slot { width: 48px; height: 48px; }
    .lb-slot--sm { width: 38px; height: 38px; }
    .lb-hero-area { grid-template-columns: 56px 1fr 56px; }
}
